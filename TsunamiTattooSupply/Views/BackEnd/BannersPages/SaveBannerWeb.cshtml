<!-- ========================================= -->
<!--  BRAND IMAGE VIEW MODAL (Single & Global) -->
<!-- ========================================= -->

<style>
    
    #saveBannerWebModal .modal-content {
        background: #f8f9fb;
    }

    #saveBannerWebModal .card {
        background: #ffffff;
    }

    #saveBannerWebModal .card-header {
        border-bottom: 1px solid #f1f3f5 !important;
    }

    #saveBannerWebModal .form-control {
        border: 1px solid #dfe3e8;
    }

        #saveBannerWebModal .form-control:focus {
            border-color: #0d6efd;
            box-shadow: none;
        }

    .bannerWeb-status-box {
        background: #f8f9fb;
        border: 1px solid #e9ecef;
    }

    .banner-web-image-box {
        border: 2px dashed #d9dee7 !important;
        transition: all 0.25s ease;
        overflow: hidden;
    }
     
         
</style>

<div class="modal fade" id="imageBannerWebViewModal" tabindex="-1" aria-hidden="true" style="background: rgba(0,0,0,0.5); z-index:99999 !important">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">

            <div class="modal-body d-flex justify-content-center align-items-center p-0"
                 style="background: rgba(0,0,0,0.9); border-radius: 10px;">

                <img id="imageBannerWebViewModalImg"
                     src=""
                     class="img-fluid rounded shadow-lg"
                     style="object-fit: contain; border-radius: 10px;" />

                <!-- Close Button -->
                <button type="button"
                        class="btn position-absolute top-0 end-0 m-3"
                        data-bs-dismiss="modal"
                        aria-label="Close"
                        style="background: rgba(255,255,255,.6); border-radius: 50%; width: 45px; height: 45px;">
                    <i class="fas fa-times text-white fs-4"></i>
                </button>

            </div>
        </div>
    </div>
</div>

<div class="modal fade fullmodal-right" id="saveBannerWebModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content border-0 shadow rounded-4 overflow-hidden">

            <div class="modal-header bg-white border-bottom px-4 py-3">
                <div>
                    <h5 id="modalBannerWebTitle" class="modal-title fw-bold mb-0">Create New BannerWeb</h5>
                    <small class="text-muted">Manage bannerWeb image and details</small>
                </div>

                <button type="button" class="btn-close border-0" data-bs-dismiss="modal"></button>
            </div>

            <form id="bannerWebForm" method="post" class="d-flex flex-column flex-grow-1">

                <div class="modal-body bg-light px-4 py-4">

                    <input id="BannerWebID" type="hidden" value="0" />
                    <input id="BannerWebTypeID" type="hidden" value="" />

                    <div class="row g-4">

                        <!-- IMAGE CARD -->
                        <div class="col-lg-5 col-12">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                                    <h6 class="mb-1 fw-bold">BannerWeb Image</h6>
                                    <small class="text-muted">Upload and preview bannerWeb image</small>
                                </div>

                                <div class="card-body d-flex align-items-center justify-content-center px-4 pb-4">

                                    <div id="dBannerWebImage" class="text-center w-100">

                                        <div class="image-box-wrapper mx-auto position-relative"
                                             style="width:250px; height:250px;">

                                            <!-- Main Box -->
                                            <div class="banner-web-image-box border rounded d-flex align-items-center justify-content-center bg-light position-relative"
                                                 style="width:100%; height:100%; cursor:pointer;">

                                                <input type="file"
                                                       id="bannerWebImage"
                                                       name="bannerWebImage"
                                                       accept="image/*"
                                                       style="display:none;" />

                                                <span class="text-muted placeholder-icon" style="font-size:50px;">
                                                    <i class="fas fa-image"></i>
                                                </span>

                                                <img id="bannerWebImagePreview"
                                                     class="img-fluid rounded d-none"
                                                     style="width:100%; height:100%; object-fit:contain;" />
                                            </div>

                                            <!-- Overlay Buttons -->
                                            <div class="image-overlay d-flex flex-column justify-content-center align-items-center">
                                                <div class="d-flex gap-4">
                                                    <button type="button" class="overlay-btn btn-clear-Web" title="Clear">
                                                        <i class="fas fa-times"></i>
                                                    </button>

                                                    <button type="button" class="overlay-btn btn-view-Web" title="View">
                                                        <i class="fas fa-eye"></i>
                                                    </button>

                                                    <button type="button" class="overlay-btn btn-browse-web" title="Browse">
                                                        <i class="fas fa-paperclip"></i>
                                                    </button>
                                                </div>
                                            </div>

                                        </div>

                                        <div class="mt-3 text-muted small">
                                            Max image size: 100 KB
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <!-- DETAILS CARD -->
                        <div class="col-lg-7 col-12">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                                    <h6 class="mb-1 fw-bold">BannerWeb Details</h6>
                                    <small class="text-muted">Enter bannerWeb information</small>
                                </div>

                                <div class="card-body px-4 pb-4">

                                    <div class="mb-4">
                                        <label for="BannerWebDescription" class="form-label fw-semibold">Description</label>
                                        <input type="text"
                                               class="form-control form-control-lg rounded-3"
                                               id="BannerWebDescription"
                                               name="BannerWebDescription"
                                               placeholder="Fill Description" />
                                        <div id="BannerWebDescriptionMessage" class="text-danger small mt-1"></div>
                                    </div>
                                     

                                    <div class="mb-4">
                                        <label for="BannerWebLink" class="form-label fw-semibold">Link</label>
                                        <input type="text"
                                               class="form-control form-control-lg rounded-3"
                                               id="BannerWebLink"
                                               name="BannerWebLink"
                                               placeholder="Fill Sentence" />
                                        <div id="BannerWebLinkMessage" class="text-danger small mt-1"></div>
                                    </div>

                                         <div class="mt-4">



                                        <!-- DATE RANGE -->
                                        <div id="BannerWebDateRange" class="row g-3">

                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Start Date</label>
                                                <input type="date"
                                                       id="BannerWebStartDate"
                                                       class="form-control form-control-lg rounded-3" />
                                            </div>

                                            <div class="col-md-6">

                                                <div class="row">
                                                    <div class="col-6">
                                                        <label class="form-label fw-semibold">End Date</label>
                                                    </div>
                                                    <div class="col-6 text-right">
                                                        <div class="custom-control custom-switch mb-0">
                                                            <input type="checkbox"
                                                                   class="custom-control-input"
                                                                   id="BannerWebPresentToggle">
                                                            <label class="custom-control-label fw-semibold" for="BannerWebPresentToggle">
                                                                Present
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>


                                                <input type="date"
                                                       id="BannerWebEndDate"
                                                       class="form-control form-control-lg rounded-3" />
                                            </div>

                                        </div>

                                    </div>

                                    <div class="mt-4">

                                    <div class="bannerWeb-status-box d-flex align-items-center justify-content-between rounded-3 px-3 py-3">
                                        <div>
                                            <div class="fw-semibold">Status</div>
                                            <small class="text-muted">Enable or disable this bannerWeb</small>
                                        </div>

                                        <div class="custom-control custom-switch mb-0">
                                            <input type="checkbox"
                                                   class="custom-control-input"
                                                   id="BannerWebStatusToggle"
                                                   name="BannerWebStatusToggle"
                                                   checked>
                                            <label class="custom-control-label fw-semibold" for="BannerWebStatusToggle">
                                                Active
                                            </label>
                                            <input type="hidden" id="BannerWebStatusID" name="BannerWebStatusID" value="A">
                                        </div>
                                    </div>

                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="modal-footer bg-white border-top px-4 py-3">
                    <button type="button" class="btn btn-light border rounded-3 px-4" data-bs-dismiss="modal">
                        <i class="fas fa-ban me-1"></i> Cancel
                    </button>

                    <button id="btnSaveBannerWeb" type="button" class="btn btn-primary rounded-3 px-4">
                        <span id="btnSaveBannerWebSpinner"
                              class="spinner-border spinner-border-sm d-none me-2"
                              role="status"></span>
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
<input type="hidden" id="ClearWebImage" value="false" />

 