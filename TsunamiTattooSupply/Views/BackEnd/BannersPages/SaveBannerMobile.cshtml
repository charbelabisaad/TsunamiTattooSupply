<!-- ========================================= -->
<!--  BRAND IMAGE VIEW MODAL (Single & Global) -->
<!-- ========================================= -->

<style>

    #saveBannerMobileModal .modal-content {
    background: #f8f9fb;
    }

    #saveBannerMobileModal .card {
    background: #ffffff;
    }

    #saveBannerMobileModal .card-header {
    border-bottom: 1px solid #f1f3f5 !important;
    }

    #saveBannerMobileModal .form-control {
    border: 1px solid #dfe3e8;
    }

    #saveBannerMobileModal .form-control:focus {
    border-color: #0d6efd;
    box-shadow: none;
    }

    .bannerMobile-status-box {
    background: #f8f9fb;
    border: 1px solid #e9ecef;
    }

    .banner-mobile-image-box {
        border: 2px dashed #d9dee7 !important;
        transition: all 0.25s ease;
        overflow: hidden;
    }


</style>

<div class="modal fade" id="imageBannerMobileViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">

            <div class="modal-body d-flex justify-content-center align-items-center p-0"
            style="background: rgba(0,0,0,0.9); border-radius: 10px;">

                <img id="imageBannerMobileViewModalImg"
                src=""
                class="img-fluid rounded shadow-lg"
                style="object-fit: contain; border-radius: 10px;" />

                <!-- Close Button -->
                <button type="button"
                class="btn position-absolute top-0 end-0 m-3"
                data-bs-dismiss="modal"
                aria-label="Close"
                style="background: rgba(0,0,0,0.6); border-radius: 50%; width: 45px; height: 45px;">
                    <i class="fas fa-times text-white fs-4"></i>
                </button>

            </div>
        </div>
    </div>
</div>

<div class="modal fade fullmodal-right" id="saveBannerMobileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content border-0 shadow rounded-4 overflow-hidden">

            <div class="modal-header bg-white border-bottom px-4 py-3">
                <div>
                    <h5 id="modalBannerMobileTitle" class="modal-title fw-bold mb-0">Create New BannerMobile</h5>
                    <small class="text-muted">Manage bannerMobile image and details</small>
                </div>

                <button type="button" class="btn-close border-0" data-bs-dismiss="modal"></button>
            </div>

            <form id="bannerMobileForm" method="post" class="d-flex flex-column flex-grow-1">

                <div class="modal-body bg-light px-4 py-4">

                    <input id="BannerMobileID" type="hidden" value="0" />
                    <input id="BannerMobileTypeID" type="hidden" value="" />

                    <div class="row g-4">

                        <!-- IMAGE CARD -->
                        <div class="col-lg-5 col-12">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                                    <h6 class="mb-1 fw-bold">BannerMobile Image</h6>
                                    <small class="text-muted">Upload and preview bannerMobile image</small>
                                </div>

                                <div class="card-body d-flex align-items-center justify-content-center px-4 pb-4">

                                    <div id="dBannerMobileImage" class="text-center w-100">

                                        <div class="image-box-wrapper mx-auto position-relative"
                                        style="width:250px; height:250px;">

                                            <!-- Main Box -->
                                            <div class="banner-mobile-image-box border rounded d-flex align-items-center justify-content-center bg-light position-relative"
                                            style="width:100%; height:100%; cursor:pointer;">

                                                <input type="file"
                                                id="bannerMobileImage"
                                                name="bannerMobileImage"
                                                accept="image/*"
                                                style="display:none;" />

                                                <span class="text-muted placeholder-icon" style="font-size:50px;">
                                                    <i class="fas fa-image"></i>
                                                </span>

                                                <img id="bannerMobileImagePreview"
                                                class="img-fluid rounded d-none"
                                                style="width:100%; height:100%; object-fit:contain;" />
                                            </div>

                                            <!-- Overlay Buttons -->
                                            <div class="image-overlay d-flex flex-column justify-content-center align-items-center">
                                                <div class="d-flex gap-4">
                                                    <button type="button" class="overlay-btn btn-clear-mobile" title="Clear">
                                                        <i class="fas fa-times"></i>
                                                    </button>

                                                    <button type="button" class="overlay-btn btn-view-mobile" title="View">
                                                        <i class="fas fa-eye"></i>
                                                    </button>

                                                    <button type="button" class="overlay-btn btn-browse-mobile" title="Browse">
                                                        <i class="fas fa-paperclip"></i>
                                                    </button>
                                                </div>
                                            </div>

                                        </div>

                                        <div class="mt-3 text-muted small">
                                            Max image size: 100 KB
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <!-- DETAILS CARD -->
                        <div class="col-lg-7 col-12">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                                    <h6 class="mb-1 fw-bold">BannerMobile Details</h6>
                                    <small class="text-muted">Enter bannerMobile information</small>
                                </div>

                                <div class="card-body px-4 pb-4">

                                    <div class="mb-4">
                                        <label for="BannerMobileDescription" class="form-label fw-semibold">Description</label>
                                        <input type="text"
                                        class="form-control form-control-lg rounded-3"
                                        id="BannerMobileDescription"
                                        name="BannerMobileDescription"
                                        placeholder="Fill Description" />
                                        <div id="BannerMobileDescriptionMessage" class="text-danger small mt-1"></div>
                                    </div>

                                    <div class="mb-4">

                                        <div class="custom-control custom-radio">
                                            <input type="radio" id="BannerMobileCategoryRadio" name="BannerMobileLink" class="custom-control-input" checked>
                                            <label class="custom-control-label fw-semibold" for="BannerMobileCategoryRadio">
                                                Category
                                            </label>
                                        </div>

                                        <select class="form-control form-control-lg selectpicker rounded-3"
                                        id="BannerMobileCategory"
                                        name="BannerMobileCategory">

                                            <option value="0">Select a category</option>

                                            @foreach(var obj in Model.categories)
                                            {
                                                <option value="@obj.ID">@obj.Description</option>
                                            }

                                        </select>
                                        <div id="BannerMobileCategoryMessage" class="text-danger small mt-1"></div>
                                    </div>

                                    <div class="mb-4">

                                        <div class="custom-control custom-radio">
                                            <input type="radio" id="BannerMobileSubCategoryRadio" name="BannerMobileLink" class="custom-control-input" checked>
                                            <label class="custom-control-label fw-semibold" for="BannerMobileSubCategoryRadio">
                                               Sub Category
                                            </label>
                                        </div>

                                        <select class="form-control form-control-lg selectpicker rounded-3"
                                                id="BannerMobileSubCategory"
                                                name="BannerMobileSubCategory"
                                                data-live-search="true">
                                                 
                                                    <option value="0">Select a sub category</option>

                                                    @foreach (var obj in Model.subcategories)
                                                    {
                                                        <option value="@obj.ID">@obj.Description</option>
                                                    }
                                             
                                            </select>

                                        <div id="BannerMobileSubCategoryMessage" class="text-danger small mt-1"></div>
                                    </div>

                                    <div class="mb-4">

                                        <div class="custom-control custom-radio">
                                            <input type="radio" id="BannerMobileGroupRadio" name="BannerMobileLink" class="custom-control-input" checked>
                                            <label class="custom-control-label fw-semibold" for="BannerMobileGroupRadio">
                                                Group
                                            </label>
                                        </div>

                                        <select class="form-control form-control-lg selectpicker rounded-3"
                                                id="BannerMobileGroup"
                                                name="BannerMobileGroup"
                                                data-live-search="true">

                                            <option value="0">Select a group</option>

                                            @foreach (var obj in Model.groups)
                                            {
                                                <option value="@obj.ID">@obj.Name</option>
                                            }

                                        </select>

                                        <div id="BannerMobileGroupMessage" class="text-danger small mt-1"></div>
                                    </div>

                                    <div class="mb-4">

                                        <div class="custom-control custom-radio">
                                            <input type="radio" id="BannerMobileProductRadio" name="BannerMobileLink" class="custom-control-input" checked>
                                            <label class="custom-control-label fw-semibold" for="BannerMobileProductRadio">
                                                Product
                                            </label>
                                        </div>

                                        <select class="form-control form-control-lg selectpicker rounded-3"
                                                id="BannerMobileProduct"
                                                name="BannerMobileProduct"
                                                data-live-search="true">
                                                 
                                                    <option value="0">Select a product</option>

                                                    @foreach (var obj in Model.products)
                                                    {
                                                        <option value="@obj.ID">@obj.Name</option>
                                                    }
                                                     
                                            </select>
                                        <div id="BannerMobileProductMessage" class="text-danger small mt-1"></div>
                                    </div>

                                    <div class="mb-4">

                                        <div class="custom-control custom-radio">
                                            <input type="radio" id="BannerMobileShopNowRadio" name="BannerMobileLink" class="custom-control-input">
                                            <label class="custom-control-label fw-semibold" for="BannerMobileShopNowRadio">
                                                Shop Now
                                            </label>
                                        </div>

                                    </div>

                                    <div class="mt-4">

                                       

                                        <!-- DATE RANGE -->
                                        <div id="BannerMobileDateRange" class="row g-3">

                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Start Date</label>
                                                <input type="date"
                                                       id="BannerMobileStartDate"
                                                       class="form-control form-control-lg rounded-3" />
                                            </div>

                                            <div class="col-md-6">

                                                <div class="row">
                                                    <div class="col-6">
                                                        <label class="form-label fw-semibold">End Date</label>
                                                    </div>
                                                    <div class="col-6 text-right">
                                                        <div class="custom-control custom-switch mb-0">
                                                            <input type="checkbox"
                                                                   class="custom-control-input"
                                                                   id="BannerMobilePresentToggle">
                                                            <label class="custom-control-label fw-semibold" for="BannerMobilePresentToggle">
                                                                Present
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>

                                                
                                                <input type="date"
                                                       id="BannerMobileEndDate"
                                                       class="form-control form-control-lg rounded-3" />
                                            </div>

                                        </div>

                                    </div>

                                    <div class="mt-4">

                                        <div class="bannerMobile-status-box d-flex align-items-center justify-content-between rounded-3 px-3 py-3">
                                            <div>
                                                <div class="fw-semibold">Status</div>
                                                <small class="text-muted">Enable or disable this bannerMobile</small>
                                            </div>

                                            <div class="custom-control custom-switch mb-0">
                                                <input type="checkbox"
                                                       class="custom-control-input"
                                                       id="BannerMobileStatusToggle"
                                                       name="BannerMobileStatusToggle"
                                                       checked>
                                                <label class="custom-control-label fw-semibold" for="BannerMobileStatusToggle">
                                                    Active
                                                </label>
                                                <input type="hidden" id="BannerMobileStatusID" name="BannerMobileStatusID" value="A">
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="modal-footer bg-white border-top px-4 py-3">
                    <button type="button" class="btn btn-light border rounded-3 px-4" data-bs-dismiss="modal">
                        <i class="fas fa-ban me-1"></i> Cancel
                    </button>

                    <button id="btnSaveBannerMobile" type="button" class="btn btn-primary rounded-3 px-4">
                        <span id="btnSaveBannerMobileSpinner"
                              class="spinner-border spinner-border-sm d-none me-2"
                              role="status"></span>
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
<input type="hidden" id="ClearImageMobile" value="false" />

 
