          $(document).on("click", ".btnEditBannerMobile", function () {

            let btn = $(this);

            // =========================
            // GET DATA
            // =========================
            let id              = btn.data("id");
            let name            = btn.data("name");
            let image           = btn.data("image");
            let imagePath       = btn.data("imagepath");
            let categoryId      = btn.data("categoryid");
            let subCategoryId   = btn.data("subcategoryid");
            let productId       = btn.data("productid");
            let startDate = btn.data("startdate");
            let endDate   = btn.data("enddate");
            let present   = btn.data("present");
            let statusId        = btn.data("statusid");

            // =========================
            // SET BASIC VALUES
            // =========================
            $("#BannerMobileID").val(id);
            $("#BannerMobileDescription").val(name);

            $("#BannerMobileStatusID").val(statusId);
            $("#BannerMobileStatusToggle").prop("checked", statusId === "A");

        // =========================
        // PRESENT + DATES 🔥
        // =========================
        $("#BannerMobilePresentToggle").prop("checked", present === true || present === "true");

        $("#BannerMobileStartDate").val(formatDate(startDate));
        $("#BannerMobileEndDate").val(formatDate(endDate));

        // toggle EndDate enable/disable
        if (present === true || present === "true") {

            $("#BannerMobileEndDate").prop("disabled", true);

        } else {

            $("#BannerMobileEndDate").prop("disabled", false);

        }

            // =========================
            // CATEGORY (SELECTPICKER)
            // =========================
            $("#BannerMobileCategory")
                .val(categoryId || 0)
                .selectpicker('destroy')
                .selectpicker('render');

            // =========================
            // LOAD SUBCATEGORY + PRODUCT 🔥
            // =========================
            let selectedSub = new Set();
            if (subCategoryId && subCategoryId !== "0") {
                selectedSub.add(String(subCategoryId));
            }

            // Load subcategories then restore selection
            LoadSubCategories(true, selectedSub);

            // Delay loading products until subcategory is ready
            setTimeout(function () {

                $("#BannerMobileSubCategory")
                    .val(subCategoryId || 0)
                    .selectpicker('destroy')
                    .selectpicker('render');

                LoadProducts();

                setTimeout(function () {
                    $("#BannerMobileProduct")
                        .val(productId || 0)
                        .selectpicker('destroy')
                        .selectpicker('render');
                }, 300);

            }, 300);

            // =========================
            // IMAGE HANDLING 🔥
            // =========================
            let preview     = $("#bannerMobileImagePreview");
            let placeholder = $("#saveBannerMobileModal .placeholder-icon");

            if (image) {

                preview
                    .attr("src", imagePath + image)
                    .removeClass("d-none");

                placeholder.addClass("d-none");

                $(".btn-clear-mobile").show();
                $(".btn-view-mobile").show();

                $("#ClearImageMobile").val("false");

            } else {

                preview
                    .attr("src", "")
                    .addClass("d-none");

                placeholder.removeClass("d-none");

                $(".btn-clear-mobile").hide();
                $(".btn-view-mobile").hide();

                $("#ClearImageMobile").val("false");
            }

            // =========================
            // TITLE
            // =========================
            $("#modalBannerMobileTitle").text("Edit Banner");

            // =========================
            // SHOW MODAL
            // =========================
            $("#saveBannerMobileModal").modal("show");

        });

        function resetBannerMobileForm() {

            // =========================
            // IDs
            // =========================
            $('#BannerMobileID').val(0);
            $('#BannerMobileTypeID').val('');

            // =========================
            // Inputs
            // =========================
            $('#BannerMobileDescription').val('');

            // =========================
            // Dropdowns
            // =========================
            $('#BannerMobileCategory')
                .val(0)
                .selectpicker('destroy')
                .selectpicker('render');

            $('#BannerMobileSubCategory')
                .html('')
                .selectpicker('destroy')
                .selectpicker('render');

            $('#BannerMobileProduct')
                .html('')
                .selectpicker('refresh')
                .selectpicker('render');

            // =========================
            // 🔥 DATE TODAY
            // =========================
            let today = new Date().toISOString().split('T')[0];

            $("#BannerMobileStartDate").val(today);
            $("#BannerMobileEndDate").val("");

            // =========================
            // PRESENT
            // =========================
            $("#BannerMobilePresentToggle").prop("checked", true);
            $("#BannerMobileEndDate").prop("disabled", true);

            // =========================
            // Status
            // =========================
            $('#BannerMobileStatusToggle').prop('checked', true);
            $('#BannerMobileStatusID').val('A');

            // =========================
            // Image Reset
            // =========================
            $('#bannerMobileImage').val('');

            $('#bannerMobileImagePreview')
                .attr('src', '')
                .addClass('d-none');

            $('#saveBannerMobileModal .placeholder-icon').removeClass('d-none');

            $('#ClearImageMobile').val('false');

            // =========================
            // Validation Messages
            // =========================
            $('#BannerMobileDescriptionMessage').html('');
            $('#BannerMobileCategoryMessage').html('');
            $('#BannerMobileSubCategoryMessage').html('');
            $('#BannerMobileProductMessage').html('');

            // =========================
            // Modal Title
            // =========================
            $('#modalBannerMobileTitle').text('Create New BannerMobile');

        }

            let currentCategoryOptionIds = [];
            let subCatMetaById = {};

            $(document).on('change', '#BannerMobileCategory', function () {
                LoadSubCategories();
            });

            function LoadSubCategories(restoreSelection = false, selectedSubCatIds = new Set()) {

                let categoryId = $('#BannerMobileCategory').val();
                let subSelect  = $('#BannerMobileSubCategory');

                subSelect.empty();
                currentCategoryOptionIds = [];

                // Default option
                subSelect.append('<option value="">-- Select Sub Category --</option>');

                if (!categoryId || categoryId === "0") {
                    subSelect.selectpicker('destroy').selectpicker('render');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetSubCategories", "BannersHomeMobile")',
                    type: 'GET',
                    data: { categoryId },
                    success: function (items) {

                        (items || []).forEach(sc => {
                            let id = String(sc.id);

                            subSelect.append(`<option value="${id}">${sc.name}</option>`);

                            currentCategoryOptionIds.push(id);

                            if (!subCatMetaById[id]) {
                                subCatMetaById[id] = {
                                    id: sc.id,
                                    name: sc.name,
                                    categoryId: parseInt(categoryId)
                                };
                            }
                        });

                        subSelect.selectpicker('destroy').selectpicker('render');

                        // Restore or clear selection
                        if (restoreSelection) {
                            let validSelected = currentCategoryOptionIds.filter(
                                id => selectedSubCatIds.has(id)
                            );
                            subSelect.selectpicker('val', validSelected);
                        } else {
                            subSelect.selectpicker('val', []);
                        }

                        subSelect.selectpicker('destroy').selectpicker('render');

                        // Optional (if you use tags)
                        if (typeof renderTags === "function") {
                            renderTags();
                        }
                    },
                    error: function () {
                        toastr.error('Failed to load sub-categories');
                    }
                });
            }

            $(document).on('change', '#BannerMobileSubCategory', function () {
                LoadProducts();
            });

            function LoadProducts() {

                let categoryId     = $('#BannerMobileCategory').val();
                let subCategoryId  = $('#BannerMobileSubCategory').val();
                let productSelect  = $('#BannerMobileProduct');

                productSelect.empty();
                productSelect.append('<option value="">-- Select Product --</option>');

                if (!categoryId || categoryId === "0" || !subCategoryId || subCategoryId === "0") {
                    productSelect.selectpicker('destroy').selectpicker('render');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetProducts", "BannersHomeMobile")',
                    type: 'GET',
                    data: {
                        CategoryId: categoryId,
                        SubCategoryId: subCategoryId
                    },
                    success: function (items) {

                        productSelect.empty();
                        productSelect.append('<option value="">-- Select Product --</option>');

                        (items || []).forEach(p => {
                            productSelect.append(
                                `<option value="${p.productID}">
                                    ${p.productName} - ${p.productGroupName}
                                </option>`
                            );
                        });

                        productSelect.selectpicker('destroy').selectpicker('render');
                    },
                    error: function () {
                        toastr.error('Failed to load products');
                    }
                });
            }

        $(document).on("click", "#btnSaveBannerMobile", function (e) {

            e.preventDefault();

            let btn     = $(this);
            let spinner = $("#btnSaveBannerMobileSpinner");

            let id            = $("#BannerMobileID").val();
            let description   = $("#BannerMobileDescription").val().trim();
            let statusId      = $("#BannerMobileStatusID").val();

            let categoryId    = $("#BannerMobileCategory").val();
            let subCategoryId = $("#BannerMobileSubCategory").val();
            let productId     = $("#BannerMobileProduct").val();

            let present   = $("#BannerMobilePresentToggle").is(":checked");
            let startDate = $("#BannerMobileStartDate").val();
            let endDate   = $("#BannerMobileEndDate").val();

            let imageFile     = $("#bannerMobileImage")[0].files[0];
            let clearImage    = $("#ClearImageMobile").val();
            let pageLocationId = $("#BannerLocationPage").val();

            let isValid = true;

            // =========================
            // Reset messages
            // =========================
            $(".text-danger").html("");

            // =========================
            // Validation
            // =========================
            if (description === "") {
                $("#BannerMobileDescriptionMessage").html("Description is required");
                isValid = false;
            }

            if (!categoryId || categoryId === "0") {
                $("#BannerMobileCategoryMessage").html("Category is required");
                isValid = false;
            }

            if (!subCategoryId || subCategoryId === "0") {
                $("#BannerMobileSubCategoryMessage").html("Sub Category is required");
                isValid = false;
            }

            if (!productId || productId === "0") {
                $("#BannerMobileProductMessage").html("Product is required");
                isValid = false;
            }

            if (id === "0" && !imageFile) {
                toastr.error("Image is required");
                isValid = false;
            }

            if (!present) {

                if (!startDate) {
                    toastr.error("Start Date is required");
                    isValid = false;
                }

                if (!endDate) {
                    toastr.error("End Date is required");
                    isValid = false;
                }

                if (startDate && endDate && startDate > endDate) {
                    toastr.error("Start Date must be before End Date");
                    isValid = false;
                }
            }

            if (!isValid) return;

            // =========================
            // UI Loading
            // =========================
            spinner.removeClass("d-none");
            btn.prop("disabled", true);

            // =========================
            // FIX NULL VALUES 🔥
            // =========================
            categoryId    = categoryId === "0" ? null : categoryId;
            subCategoryId = subCategoryId === "0" ? null : subCategoryId;
            productId     = productId === "0" ? null : productId;

            // =========================
            // FormData
            // =========================
            let formData = new FormData();

            formData.append("ID", id);
            formData.append("Description", description);
            formData.append("StatusID", statusId);
            formData.append("PageLocationID", pageLocationId);

            if (categoryId !== null)    formData.append("CategoryID", categoryId);
            if (subCategoryId !== null) formData.append("SubCategoryID", subCategoryId);
            if (productId !== null)     formData.append("ProductID", productId);

            formData.append("Present", present);

             formData.append("StartDate", startDate || "");

            if (!present) { 
                formData.append("EndDate", endDate || "");
            } else { 
                formData.append("EndDate", "");
            }

            formData.append("ClearImageMobile", clearImage ?? "false");

            if (imageFile) {
                formData.append("Image", imageFile);
            }

            // =========================
            // AJAX
            // =========================
            $.ajax({
                url: '@Url.Action("SaveBannerMobile", "BannersPages")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,

                success: function (response) {

                    spinner.addClass("d-none");
                    btn.prop("disabled", false);

                    if (response.success) {

                        toastr.success(response.message);

                        $("#saveBannerMobileModal").modal("hide");

                        $("#tableBannersMobile").DataTable().ajax.reload(null, false);

                    } else {

                        toastr.error(response.message);

                    }
                },

                error: function () {

                    spinner.addClass("d-none");
                    btn.prop("disabled", false);

                    toastr.error("Something went wrong");

                }
            });

        });

        $(document).on("click", ".btnDeleteBannerMobile", function () {

            let id = $(this).data("id");

            // set hidden input
            $("#deletedBannerMobileId").val(id);

            // reset message
            $("#deleteModalBannerMobileMessage").hide().html("");

            // optional text
            $("#deleteBannerMobileMessage").text("Are you sure you want to delete this Banner?");

            // show modal
            $("#deleteBannerMobileModal").modal("show");

        });

                $(document).on("click", "#btnConfirmDeleteBannerMobile", function () {

            let btn     = $(this);
            let spinner = $("#btnDeleteBannerMobileSpinner");

            let id = $("#deletedBannerMobileId").val();

            if (!id || id === "0") return;

            // =========================
            // UI LOADING
            // =========================
            spinner.removeClass("d-none");
            btn.prop("disabled", true);

            // =========================
            // AJAX
            // =========================
            $.ajax({
                url: '@Url.Action("DeleteBannerMobile", "BannersPages")',
                type: "POST",
                data: { id: id },

                success: function (response) {

                    spinner.addClass("d-none");
                    btn.prop("disabled", false);

                    if (response.success) {

                        toastr.success(response.message);

                        $("#deleteBannerMobileModal").modal("hide");

                        // 🔥 reload table
                        $("#tableBannersMobile").DataTable().ajax.reload(null, false);

                        $("#deletedBannerMobileId").val(0);

                    } else {

                        $("#deleteModalBannerMobileMessage")
                            .html(response.message)
                            .show();
                    }
                },

                error: function () {

                    spinner.addClass("d-none");
                    btn.prop("disabled", false);

                    $("#deleteModalBannerMobileMessage")
                        .html("Something went wrong")
                        .show();
                }
            });

        });


        });
  
    </script>
