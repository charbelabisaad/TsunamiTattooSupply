@model TsunamiTattooSupply.ViewModels.PageViewModel

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Banners Pages";
}

<style>

    .custom-tabs {
        border-bottom: 1px solid #dee2e6;
        margin-bottom: 20px;
    }

    .custom-tabs .nav-link {
        border: none !important;
        border-radius: 0;
        color: #6c757d;
        font-weight: 600;
        background-color: transparent !important;
        padding: 12px 20px;
        position: relative;
        outline: none !important;
        box-shadow: none !important;
    }

    .custom-tabs .nav-link:hover,
    .custom-tabs .nav-link:focus,
    .custom-tabs .nav-link:active {
        color: #0d6efd;
        outline: none !important;
        box-shadow: none !important;
        border: none !important;
    }

    .custom-tabs .nav-link.active {
        color: #0d6efd !important;
        background-color: transparent !important;
        outline: none !important;
        box-shadow: none !important;
        border: none !important;
    }

    .custom-tabs .nav-link.active::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -1px;
        width: 100%;
        height: 3px;
        background-color: #0d6efd;
        border-radius: 2px 2px 0 0;
    }

    .page-location-wrapper {
        margin-bottom: 20px;
    }

    .page-location-button {
        min-width: 140px;
        margin-right: 8px;
        margin-bottom: 8px;
        border-radius: 8px;
        outline: none !important;
        box-shadow: none !important;
    }

    .page-location-button:focus,
    .page-location-button:active {
        outline: none !important;
        box-shadow: none !important;
    }

        .page-location-button.btn-outline-dark:hover {
            background-color: whitesmoke;
            color: #000000;
        }

        .page-location-button.btn-dark:hover {
            background-color: #343a40;
            color: #ffffff;
            border-color: #343a40;
            cursor:default;
        }

    a:focus,
    button:focus {
        outline: none !important;
        box-shadow: none !important;
    }

</style>

<partial name="DeleteBannerWeb" />
<partial name="SaveBannerWeb" /> 
<partial name="DeleteBannerMobile" />
<partial name="SaveBannerMobile" />

<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div>
            </div>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header">

                    <div class="row">
                        <div class="col-6 d-flex align-groups-center"><h3 class="card-title">Banners Pages List</h3></div>
                        <div class="col-6 d-flex align-groups-center justify-content-end">
                            <button id="btnNewBanner" type="button" class="btn btn-sm btn-black"><i class="fas fa-plus"></i> Add New Banner</button>
                            <button id="btnSetRankBanner" type="button" class="btn btn-sm btn-primary btn-rank ml-3 d-none"><i class="fa-solid fa-arrow-down-1-9"></i> Set Rank</button>
                        </div>
                    </div>
                     
                </div>

                <div class="card-body">

                    <ul class="nav nav-tabs custom-tabs" id="bannersTabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active"
                               id="web-tab"
                               data-toggle="tab"
                               href="#web-pane"
                               role="tab"
                               aria-controls="web-pane"
                               aria-selected="true">
                                Web
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               id="mobile-tab"
                               data-toggle="tab"
                               href="#mobile-pane"
                               role="tab"
                               aria-controls="mobile-pane"
                               aria-selected="false">
                                Mobile
                            </a>
                        </li>
                    </ul>

                    <div class="page-location-wrapper">
                        @{
                            int count = 0;
                            string selected = "";
                        }

                        @foreach (var obj in Model.locations)
                        {
                            selected = count == 0 ? "btn-dark" : "btn-outline-dark";

                            <button id="PageLocation-@obj.ID"
                                    type="button"
                                    name="PageLocation"
                                    class="btn @selected page-location-button">
                                @obj.Description
                            </button>

                            count++;
                        }
                    </div>

                    <input id="BannerAppType" type="hidden" name="BannerAppType" value="WEB" />

                    <input id="BannerLocationPage" type="hidden" name="BannerLocationPage" />

                    <div class="tab-content pt-2" id="bannersTabsContent">

                        <div class="tab-pane fade show active" id="web-pane" role="tabpanel" aria-labelledby="web-tab">
                            <table id="tableBannersAdWeb" class="table table-striped w-100">
                                <thead>
                                    <tr style="vertical-align:middle">
                                        <th style="width:100px">Image</th>
                                        <th style="width:200px">Name</th>
                                        <th>Link</th>
                                        <th style="width:50px">Status</th>
                                        <th style="width:50px" class="no-export">Actions</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>

                        <div class="tab-pane fade" id="mobile-pane" role="tabpanel" aria-labelledby="mobile-tab">
                            <table id="tableBannersMobile" class="table table-striped w-100">
                                <thead>
                                    <tr style="vertical-align:middle">
                                        <th style="width:100px">Image</th>
                                        <th style="width:20%">Name</th>
                                        <th style="width:20%">Category</th>
                                        <th style="width:20%">SubCategory</th>
                                        <th style="width:20%">Product</th>
                                        <th style="width:50px">Status</th>
                                        <th style="width:50px" class="no-export">Actions</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>

        $(document).ready(function(){

            $('#web-tab').on('click', function () {
                $('#BannerAppType').val('WEB');
            });

            $('#mobile-tab').on('click', function () {
                $('#BannerAppType').val('MOBILE');
            });

            $(document).on('click','#btnNewBanner ', function(){
                   
                if ($('#BannerAppType').val() === 'WEB') {
                         
                    ShowBannerWebModal();

                } else if ($('#BannerAppType').val() === 'MOBILE') {
                         
                    ShowBannerMobileModal();

                }
                     
            });

            function ShowBannerWebModal(){

                resetBannerWebForm();
                $("#saveBannerWebModal").modal("show");

            }

            function ShowBannerMobileModal(){

                resetBannerMobileForm();
                $("#saveBannerMobileModal").modal("show");

            }
     
            $(document).on('click', '.page-location-button', function () {
                $('.page-location-button')
                    .removeClass('btn-dark')
                    .addClass('btn-outline-dark');

                $(this)
                    .removeClass('btn-outline-dark')
                    .addClass('btn-dark');
            });

            $(document).on('click', '.page-location-button', function () {

                $('.page-location-button')
                    .removeClass('btn-dark')
                    .addClass('btn-outline-dark');

                $(this)
                    .removeClass('btn-outline-dark')
                    .addClass('btn-dark');

                // 🔥 SET VALUE
                let id = $(this).attr("id").split("-")[1];
                $("#BannerLocationPage").val(id);

            });

            ///////////////////////////////////////////////////// BANNER WEB /////////////////////////////////////////////////////


            const wrapperWeb = document.querySelector("#saveBannerWebModal .image-box-wrapper");

            if (wrapperWeb) {

                const input       = wrapperWeb.querySelector("#bannerWebImage");
                const preview     = wrapperWeb.querySelector("#bannerWebImagePreview");
                const placeholder = wrapperWeb.querySelector(".placeholder-icon");
                const clearBtn    = wrapperWeb.querySelector(".btn-clear-Web");
                const viewBtn     = wrapperWeb.querySelector(".btn-view-Web");
                const browseBtn   = wrapperWeb.querySelector(".btn-browse-web");

                let dialogOpen = false;

                clearBtn.style.display = "none";
                viewBtn.style.display  = "none";

                function resetBannerWebImage(clearImageValue = "false") {
                    input.value = "";
                    preview.src = "";
                    preview.classList.add("d-none");
                    placeholder.classList.remove("d-none");

                    clearBtn.style.display = "none";
                    viewBtn.style.display  = "none";

                    $("#ClearWebImage").val(clearImageValue);
                }

                // =========================
                // Browse Button
                // =========================
                browseBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (dialogOpen) return;

                    dialogOpen = true;

                    setTimeout(() => input.click(), 0);
                });

                // =========================
                // On File Select
                // =========================
                input.addEventListener("change", function () {
                    dialogOpen = false;

                    const file = this.files[0];
                    if (!file) return;

                    const maxSizeKB = 150;
                    const maxSizeBytes = maxSizeKB * 1024;

                    if (file.size > maxSizeBytes) {
                        toastr.error("Image size must not exceed 150 KB");
                        resetBannerWebImage("false");
                        return;
                    }

                    const reader = new FileReader();

                    reader.onload = function (e) {
                        const img = new Image();

                        img.onload = function () {

                            const requiredWidth  = 1920;
                            const requiredHeight = 1000;

                            if (img.width !== requiredWidth || img.height !== requiredHeight) {
                                toastr.error("Image dimensions must be exactly 1920 x 1000 pixels");
                                resetBannerWebImage("false");
                                return;
                            }

                            preview.src = e.target.result;
                            preview.classList.remove("d-none");
                            placeholder.classList.add("d-none");

                            clearBtn.style.display = "inline-block";
                            viewBtn.style.display  = "inline-block";

                            $("#ClearWebImage").val("false");
                        };

                        img.src = e.target.result;
                    };

                    reader.readAsDataURL(file);
                });

                // =========================
                // Dialog safety
                // =========================
                input.addEventListener("click", function () {
                    setTimeout(() => dialogOpen = false, 1000);
                });

                // =========================
                // Clear Image
                // =========================
                clearBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    resetBannerWebImage("true");
                });

                // =========================
                // View Image Modal
                // =========================
                viewBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (!preview.src) return;

                    $("#imageBannerWebViewModalImg").attr("src", preview.src);
                    new bootstrap.Modal(document.getElementById("imageBannerWebViewModal")).show();
                });
            }


                    var tableBannersWeb = $('#tableBannersAdWeb').DataTable({
            processing: true,
            responsive: true,

            ajax: {
                url: '@Url.Action("ListGetBannersWeb", "BannersPages")',
                type: 'GET',
                data: function (d) {
                    d.PageLocationID = $('#BannerLocationPage').val();
                },
                dataSrc: function (json) {

                    if (json && json.success === false) {
                        toastr.error(json.message || "Failed to load banners.");
                        return [];
                    }

                    if (!json || !json.data) {
                        toastr.error("Unexpected response from server.");
                        return [];
                    }

                    return json.data;
                }
            },

            dom:
                '<"row mb-2"<"col-md-6"f><"col-md-6 text-right"B>>t' +
                '<"row mt-2 mb-2 d-flex align-items-center"' +
                '<"col-md-6 d-flex align-items-center" l>' +
                '<"col-md-4 d-flex align-items-center justify-content-end" i>' +
                '<"col-md-2 d-flex justify-content-end" p>' +
                '>',

            language: {
                search: "",
                searchPlaceholder: "Search banners..."
            },

            buttons: [
                {
                    extend: 'copy',
                    className: 'btn btn-secondary btn-sm',
                    exportOptions: { columns: ':visible:not(.no-export)' },
                    text: '<i class="fas fa-copy"></i> Copy'
                },
                {
                    extend: 'excel',
                    className: 'btn btn-success btn-sm',
                    exportOptions: { columns: ':visible:not(.no-export)' },
                    text: '<i class="fas fa-file-excel"></i> Excel'
                },
                {
                    extend: 'pdfHtml5',
                    className: 'btn btn-danger btn-sm',
                    exportOptions: { columns: ':visible:not(.no-export)' },
                    text: '<i class="fas fa-file-pdf"></i> PDF'
                },
                {
                    extend: 'print',
                    className: 'btn btn-dark btn-sm',
                    exportOptions: { columns: ':visible:not(.no-export)' },
                    text: '<i class="fas fa-print"></i> Print'
                },
                {
                    text: '<i class="fas fa-sync"></i> Refresh',
                    className: 'btn btn-primary btn-sm',
                    action: function () {
                        tableBannersWeb.ajax.reload();
                    }
                }
            ],

            columns: [

                // 🔹 Image
                {
                    data: "image",
                    className: "align-middle",
                    render: function (data, type, row) {

                        if (!row.image) {
                            return `<span class="text-muted">No Image</span>`;
                        }

                        return `
                            <img src="${row.imagePath}${row.image}"
                                 style="width:70px;height:70px;object-fit:contain;border-radius:4px;cursor:pointer"
                                 class="bannerImagePreviewWeb"
                                 data-img="${row.image}"
                                 data-imagepath="${row.imagePath}">
                        `;
                    }
                },

                // 🔹 Name
                {
                    data: "name",
                    className: "align-middle"
                },

                // 🔹 Link
                {
                    data: "link",
                    className: "align-middle",
                    render: function (data) {
                        if (!data) {
                            return '<span class="text-muted">-</span>';
                        }

                        return `<a href="${data}" target="_blank">${data}</a>`;
                    }
                },

                // 🔹 Status
                {
                    data: "status",
                    className: "align-middle text-center",
                    render: function (data, type, row) {
                        return `
                            <div class="badge text-white"
                                 style="background-color:#${row.statusColor}; width:100px;">
                                ${data}
                            </div>
                        `;
                    }
                },

                // 🔹 Actions
                {
                    data: null,
                    orderable: false,
                    searchable: false,
                    className: "no-export text-center align-middle",
                    render: function (data, type, row) {

                        return `
                        <div class="dropdown">
                            <button class="btn btn-sm btn-light" type="button" data-toggle="dropdown">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>

                            <div class="dropdown-menu">

                                <a class="dropdown-item btnEditBannerWeb"
                                   data-id="${row.id}"
                                   data-name="${row.name ?? ''}"
                                   data-link="${row.link ?? ''}"
                                   data-image="${row.image ?? ''}"
                                   data-imagepath="${row.imagePath ?? ''}"
                                   data-statusid="${row.statusID}">
                                    <i class="fas fa-edit"></i> Edit
                                </a>

                                <a class="dropdown-item btnDeleteBannerWeb"
                                   data-id="${row.id}">
                                    <i class="fas fa-trash"></i> Delete
                                </a>

                            </div>
                        </div>
                        `;
                    }
                }
            ],

            order: [[1, "asc"]]
        });

            function resetBannerWebForm() {

                // =========================
                // IDs
                // =========================
                $('#BannerWebID').val(0);
                $('#BannerWebTypeID').val('');

                // =========================
                // Inputs
                // =========================
                $('#BannerWebDescription').val('');
                $('#BannerWebSentence').val('');
                $('#BannerWebLink').val('');

                // =========================
                // Status
                // =========================
                $('#BannerWebStatusToggle').prop('checked', true);
                $('#BannerWebStatusID').val('A');

                // =========================
                // Image Reset
                // =========================
                $('#bannerWebImage').val('');

                $('#bannerWebImagePreview')
                    .attr('src', '')
                    .addClass('d-none');

                // show placeholder again
                $('#saveBannerWebModal .placeholder-icon').removeClass('d-none');

                // reset clear flag
                $('#ClearWebImage').val('false');

                // =========================
                // Validation Messages
                // =========================
                $('#BannerWebDescriptionMessage').html('');
                $('#BannerWebSentenceMessage').html('');
                $('#BannerWebLinkMessage').html('');

                // =========================
                // Modal Title
                // =========================
                $('#modalBannerWebTitle').text('Create New BannerWeb');

            }

            $(document).on("click", "#btnSaveBannerWeb", function (e) {

                e.preventDefault();

                let btn     = $(this);
                let spinner = $("#btnSaveBannerWebSpinner");

                let id          = $("#BannerWebID").val();
                let description = $("#BannerWebDescription").val().trim();
                let sentence    = $("#BannerWebSentence").val().trim();
                let link        = $("#BannerWebLink").val().trim();
                let statusId    = $("#BannerWebStatusID").val();
                let imageFile   = $("#bannerWebImage")[0].files[0];
                let clearImage  = $("#ClearWebImage").val();
                let pageLocationId = $("#BannerLocationPage").val();

                let isValid = true;

                // =========================
                // Reset messages
                // =========================
                $("#BannerWebDescriptionMessage").html("");
                $("#BannerWebSentenceMessage").html("");
                $("#BannerWebLinkMessage").html("");

                // =========================
                // Validation
                // =========================
                if (description === "") {
                    $("#BannerWebDescriptionMessage").html("Description is required");
                    isValid = false;
                }

                if (id === "0" && !imageFile) {
                    toastr.error("Image is required");
                    isValid = false;
                }

                if (!isValid) return;

                // =========================
                // UI Loading
                // =========================
                spinner.removeClass("d-none");
                btn.prop("disabled", true);

                // =========================
                // FormData
                // =========================
                let formData = new FormData();

                formData.append("ID", id);
                formData.append("Description", description);
                formData.append("Sentence", sentence);
                formData.append("Link", link);
                formData.append("StatusID", statusId);
                formData.append("PageLocationID", pageLocationId);
                formData.append("ClearWebImage", clearImage);

                if (imageFile) {
                    formData.append("Image", imageFile);
                }

                // =========================
                // AJAX
                // =========================
                $.ajax({
                    url: '@Url.Action("SaveBannerWeb", "BannersPages")',
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,

                    success: function (response) {

                        spinner.addClass("d-none");
                        btn.prop("disabled", false);

                        if (response.success) {

                            toastr.success(response.message);

                            $("#saveBannerWebModal").modal("hide");

                            // 🔥 reload table
                            $("#tableBannersAdWeb").DataTable().ajax.reload(null, false);

                        } else {

                            toastr.error(response.message);

                        }
                    },

                    error: function () {

                        spinner.addClass("d-none");
                        btn.prop("disabled", false);

                        toastr.error("Something went wrong");

                    }
                });

            });

            ///////////////////////////////////////////////////// BANNER MOBILE /////////////////////////////////////////////////////
             
            const wrapperMobile = document.querySelector("#saveBannerMobileModal .image-box-wrapper");

            if (wrapperMobile) {

                const input       = wrapperMobile.querySelector("#bannerMobileImage");
