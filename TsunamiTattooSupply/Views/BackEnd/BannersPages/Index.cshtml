@model TsunamiTattooSupply.ViewModels.PageViewModel

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Banners Pages";
}

<style>

    .custom-tabs {
        border-bottom: 1px solid #dee2e6;
        margin-bottom: 20px;
    }

    .custom-tabs .nav-link {
        border: none !important;
        border-radius: 0;
        color: #6c757d;
        font-weight: 600;
        background-color: transparent !important;
        padding: 12px 20px;
        position: relative;
        outline: none !important;
        box-shadow: none !important;
    }

    .custom-tabs .nav-link:hover,
    .custom-tabs .nav-link:focus,
    .custom-tabs .nav-link:active {
        color: #0d6efd;
        outline: none !important;
        box-shadow: none !important;
        border: none !important;
    }

    .custom-tabs .nav-link.active {
        color: #0d6efd !important;
        background-color: transparent !important;
        outline: none !important;
        box-shadow: none !important;
        border: none !important;
    }

    .custom-tabs .nav-link.active::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -1px;
        width: 100%;
        height: 3px;
        background-color: #0d6efd;
        border-radius: 2px 2px 0 0;
    }

    .page-location-wrapper {
        margin-bottom: 20px;
    }

    .page-location-button {
        min-width: 140px;
        margin-right: 8px;
        margin-bottom: 8px;
        border-radius: 8px;
        outline: none !important;
        box-shadow: none !important;
    }

    .page-location-button:focus,
    .page-location-button:active {
        outline: none !important;
        box-shadow: none !important;
    }

        .page-location-button.btn-outline-dark:hover {
            background-color: whitesmoke;
            color: #000000;
        }

        .page-location-button.btn-dark:hover {
            background-color: #343a40;
            color: #ffffff;
            border-color: #343a40;
            cursor:default;
        }

    a:focus,
    button:focus {
        outline: none !important;
        box-shadow: none !important;
    }

</style>

<partial name="DeleteBannerWeb" />
<partial name="SaveBannerWeb" /> 
<partial name="DeleteBannerMobile" />
<partial name="SaveBannerMobile" />

<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div>
            </div>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="card">
                <div class="card-header">

                    <div class="row">
                        <div class="col-6 d-flex align-groups-center"><h3 class="card-title">Banners Pages List</h3></div>
                        <div class="col-6 d-flex align-groups-center justify-content-end">
                            <button id="btnNewBanner" type="button" class="btn btn-sm btn-black"><i class="fas fa-plus"></i> Add New Banner</button>
                            <button id="btnSetRankBanner" type="button" class="btn btn-sm btn-primary btn-rank ml-3 d-none"><i class="fa-solid fa-arrow-down-1-9"></i> Set Rank</button>
                        </div>
                    </div>
                     
                </div>

                <div class="card-body">

                    <ul class="nav nav-tabs custom-tabs" id="bannersTabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active"
                               id="web-tab"
                               data-toggle="tab"
                               href="#web-pane"
                               role="tab"
                               aria-controls="web-pane"
                               aria-selected="true">
                                Web
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               id="mobile-tab"
                               data-toggle="tab"
                               href="#mobile-pane"
                               role="tab"
                               aria-controls="mobile-pane"
                               aria-selected="false">
                                Mobile
                            </a>
                        </li>
                    </ul>

                    <div class="page-location-wrapper">
                        @{
                            int count = 0;
                            string selected = "";
                        }

                        @foreach (var obj in Model.locations)
                        {
                            selected = count == 0 ? "btn-dark" : "btn-outline-dark";

                            <button id="PageLocation-@obj.ID"
                                    type="button"
                                    name="PageLocation"
                                    class="btn @selected page-location-button">
                                @obj.Description
                            </button>

                            count++;
                        }
                    </div>

                    <input id="BannerAppType" type="hidden" name="BannerAppType" value="WEB" />

                    <input id="BannerLocationPage" type="hidden" name="BannerLocationPage" />

                    <div class="tab-content pt-2" id="bannersTabsContent">

                        <div class="tab-pane fade show active" id="web-pane" role="tabpanel" aria-labelledby="web-tab">
                            <table id="tableBannersAdWeb" class="table table-striped w-100">
                                <thead>
                                    <tr style="vertical-align:middle">
                                        <th style="width:100px">Image</th>
                                        <th style="width:200px">Name</th>
                                        <th>Link</th>
                                        <th style="width:50px">Status</th>
                                        <th style="width:50px" class="no-export">Actions</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>

                        <div class="tab-pane fade" id="mobile-pane" role="tabpanel" aria-labelledby="mobile-tab">
                            <table id="tableBannersMobile" class="table table-striped w-100">
                                <thead>
                                    <tr style="vertical-align:middle">
                                        <th style="width:100px">Image</th>
                                        <th style="width:20%">Name</th>
                                        <th style="width:20%">Category</th>
                                        <th style="width:20%">SubCategory</th>
                                        <th style="width:20%">Product</th>
                                        <th style="width:50px">Status</th>
                                        <th style="width:50px" class="no-export">Actions</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>

        $(document).ready(function(){

            $('#web-tab').on('click', function () {
                $('#BannerAppType').val('WEB');
            });

            $('#mobile-tab').on('click', function () {
                $('#BannerAppType').val('MOBILE');
            });

            $(document).on('click','#btnNewBanner ', function(){
                   
                if ($('#BannerAppType').val() === 'WEB') {
                         
                    ShowBannerWebModal();

                } else if ($('#BannerAppType').val() === 'MOBILE') {
                         
                    ShowBannerMobileModal();

                }
                     
            });

            function ShowBannerWebModal(){

                resetBannerWebForm();
                $("#saveBannerWebModal").modal("show");

            }

            function ShowBannerMobileModal(){

                resetBannerMobileForm();
                $("#saveBannerMobileModal").modal("show");

            }
     
            $(document).on('click', '.page-location-button', function () {
                $('.page-location-button')
                    .removeClass('btn-dark')
                    .addClass('btn-outline-dark');

                $(this)
                    .removeClass('btn-outline-dark')
                    .addClass('btn-dark');
            });

            ///////////////////////////////////////////////////// BANNER WEB /////////////////////////////////////////////////////

            const wrapperWeb = document.querySelector("#saveBannerWebModal .image-box-wrapper");

            if (wrapperWeb) {

                const input       = wrapperWeb.querySelector("#bannerWebImage");
                const preview     = wrapperWeb.querySelector("#bannerWebImagePreview");
                const placeholder = wrapperWeb.querySelector(".placeholder-icon");
                const clearBtn    = wrapperWeb.querySelector(".btn-clear-Web");
                const viewBtn     = wrapperWeb.querySelector(".btn-view-Web");
                const browseBtn   = wrapperWeb.querySelector(".btn-browse-web");

                let dialogOpen = false;

                clearBtn.style.display = "none";
                viewBtn.style.display  = "none";

                function resetBannerWebImage(clearImageValue = "false") {
                    input.value = "";
                    preview.src = "";
                    preview.classList.add("d-none");
                    placeholder.classList.remove("d-none");

                    clearBtn.style.display = "none";
                    viewBtn.style.display  = "none";

                    $("#ClearWebImage").val(clearImageValue);
                }

                // =========================
                // Browse Button
                // =========================
                browseBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (dialogOpen) return;

                    dialogOpen = true;

                    setTimeout(() => input.click(), 0);
                });

                // =========================
                // On File Select
                // =========================
                input.addEventListener("change", function () {
                    dialogOpen = false;

                    const file = this.files[0];
                    if (!file) return;

                    const maxSizeKB = 150;
                    const maxSizeBytes = maxSizeKB * 1024;

                    if (file.size > maxSizeBytes) {
                        toastr.error("Image size must not exceed 150 KB");
                        resetBannerWebImage("false");
                        return;
                    }

                    const reader = new FileReader();

                    reader.onload = function (e) {
                        const img = new Image();

                        img.onload = function () {

                            const requiredWidth  = 1920;
                            const requiredHeight = 1000;

                            if (img.width !== requiredWidth || img.height !== requiredHeight) {
                                toastr.error("Image dimensions must be exactly 1920 x 1000 pixels");
                                resetBannerWebImage("false");
                                return;
                            }

                            preview.src = e.target.result;
                            preview.classList.remove("d-none");
                            placeholder.classList.add("d-none");

                            clearBtn.style.display = "inline-block";
                            viewBtn.style.display  = "inline-block";

                            $("#ClearWebImage").val("false");
                        };

                        img.src = e.target.result;
                    };

                    reader.readAsDataURL(file);
                });

                // =========================
                // Dialog safety
                // =========================
                input.addEventListener("click", function () {
                    setTimeout(() => dialogOpen = false, 1000);
                });

                // =========================
                // Clear Image
                // =========================
                clearBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    resetBannerWebImage("true");
                });

                // =========================
                // View Image Modal
                // =========================
                viewBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (!preview.src) return;

                    $("#imageBannerWebViewModalImg").attr("src", preview.src);
                    new bootstrap.Modal(document.getElementById("imageBannerWebViewModal")).show();
                });
            }

            function resetBannerWebForm() {

                // =========================
                // IDs
                // =========================
                $('#BannerWebID').val(0);
                $('#BannerWebTypeID').val('');

                // =========================
                // Inputs
                // =========================
                $('#BannerWebDescription').val('');
                $('#BannerWebSentence').val('');
                $('#BannerWebLink').val('');

                // =========================
                // Status
                // =========================
                $('#BannerWebStatusToggle').prop('checked', true);
                $('#BannerWebStatusID').val('A');

                // =========================
                // Image Reset
                // =========================
                $('#bannerWebImage').val('');

                $('#bannerWebImagePreview')
                    .attr('src', '')
                    .addClass('d-none');

                // show placeholder again
                $('#saveBannerWebModal .placeholder-icon').removeClass('d-none');

                // reset clear flag
                $('#ClearWebImage').val('false');

                // =========================
                // Validation Messages
                // =========================
                $('#BannerWebDescriptionMessage').html('');
                $('#BannerWebSentenceMessage').html('');
                $('#BannerWebLinkMessage').html('');

                // =========================
                // Modal Title
                // =========================
                $('#modalBannerWebTitle').text('Create New BannerWeb');

            }

            ///////////////////////////////////////////////////// BANNER MOBILE /////////////////////////////////////////////////////

            const wrapperMobile = document.querySelector("#saveBannerMobileModal .image-box-wrapper");

            if (wrapperMobile) {

                const input       = wrapperMobile.querySelector("#bannerMobileImage");
                const preview     = wrapperMobile.querySelector("#bannerMobileImagePreview");
                const placeholder = wrapperMobile.querySelector(".placeholder-icon");
                const clearBtn    = wrapperMobile.querySelector(".btn-clear-mobile");
                const viewBtn     = wrapperMobile.querySelector(".btn-view-mobile");
                const browseBtn   = wrapperMobile.querySelector(".btn-browse-mobile");

                let dialogOpen = false;

                clearBtn.style.display = "none";
                viewBtn.style.display  = "none";

                function resetBannerMobileImage(clearImageValue = "false") {
                    input.value = "";
                    preview.src = "";
                    preview.classList.add("d-none");
                    placeholder.classList.remove("d-none");

                    clearBtn.style.display = "none";
                    viewBtn.style.display  = "none";

                    $("#ClearImageMobile").val(clearImageValue);
                }

                // =========================
                // Browse Button
                // =========================
                browseBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (dialogOpen) return;

                    dialogOpen = true;

                    setTimeout(() => input.click(), 0);
                });

                // =========================
                // On File Select
                // =========================
                input.addEventListener("change", function () {
                    dialogOpen = false;

                    const file = this.files[0];
                    if (!file) return;

                    const maxSizeKB = 150;
                    const maxSizeBytes = maxSizeKB * 1024;

                    if (file.size > maxSizeBytes) {
                        toastr.error("Image size must not exceed 150 KB");
                        resetBannerMobileImage("false");
                        return;
                    }

                    const reader = new FileReader();

                    reader.onload = function (e) {
                        const img = new Image();

                        img.onload = function () {

                            // 🔥 You can change mobile dimensions if needed
                            const requiredWidth  = 800;
                            const requiredHeight = 600;

                            if (img.width !== requiredWidth || img.height !== requiredHeight) {
                                toastr.error("Image dimensions must be exactly 800 x 600 pixels");
                                resetBannerMobileImage("false");
                                return;
                            }

                            preview.src = e.target.result;
                            preview.classList.remove("d-none");
                            placeholder.classList.add("d-none");

                            clearBtn.style.display = "inline-block";
                            viewBtn.style.display  = "inline-block";

                            $("#ClearImageMobile").val("false");
                        };

                        img.src = e.target.result;
                    };

                    reader.readAsDataURL(file);
                });

                // =========================
                // Dialog safety
                // =========================
                input.addEventListener("click", function () {
                    setTimeout(() => dialogOpen = false, 1000);
                });

                // =========================
                // Clear Image
                // =========================
                clearBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    resetBannerMobileImage("true");
                });

                // =========================
                // View Image Modal
                // =========================
                viewBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (!preview.src) return;

                    $("#imageBannerMobileViewModalImg").attr("src", preview.src);
                    new bootstrap.Modal(document.getElementById("imageBannerMobileViewModal")).show();
                });
            }

            function resetBannerMobileForm() {

                // =========================
                // IDs
                // =========================
                $('#BannerMobileID').val(0);
                $('#BannerMobileTypeID').val('');

                // =========================
                // Inputs
                // =========================
                $('#BannerMobileDescription').val('');

                // =========================
                // Dropdowns (selectpicker)
                // =========================
                $('#BannerMobileCategory')
                    .val(0)
                    .selectpicker('destroy')
                    .selectpicker('render');

                $('#BannerMobileSubCategory')
                    .html('')
                    .selectpicker('destroy')
                    .selectpicker('render');

                $('#BannerMobileProduct')
                    .html('')
                    .selectpicker('refresh')
                    .selectpicker('render');

                // =========================
                // Status
                // =========================
                $('#BannerMobileStatusToggle').prop('checked', true);
                $('#BannerMobileStatusID').val('A');

                // =========================
                // Image Reset
                // =========================
                $('#bannerMobileImage').val('');

                $('#bannerMobileImagePreview')
                    .attr('src', '')
                    .addClass('d-none');

                // show placeholder again
                $('#saveBannerMobileModal .placeholder-icon').removeClass('d-none');

                // reset clear flag
                $('#ClearImageMobile').val('false');

                // =========================
                // Validation Messages
                // =========================
                $('#BannerMobileDescriptionMessage').html('');
                $('#BannerMobileCategoryMessage').html('');
                $('#BannerMobileSubCategoryMessage').html('');
                $('#BannerMobileProductMessage').html('');

                // =========================
                // Modal Title
                // =========================
                $('#modalBannerMobileTitle').text('Create New BannerMobile');

            }

            let currentCategoryOptionIds = [];
            let subCatMetaById = {};

            $(document).on('change', '#BannerMobileCategory', function () {
                LoadSubCategories();
            });

            function LoadSubCategories(restoreSelection = false, selectedSubCatIds = new Set()) {

                let categoryId = $('#BannerMobileCategory').val();
                let subSelect  = $('#BannerMobileSubCategory');

                subSelect.empty();
                currentCategoryOptionIds = [];

                // Default option
                subSelect.append('<option value="">-- Select Sub Category --</option>');

                if (!categoryId || categoryId === "0") {
                    subSelect.selectpicker('destroy').selectpicker('render');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetSubCategories", "BannersHomeMobile")',
                    type: 'GET',
                    data: { categoryId },
                    success: function (items) {

                        (items || []).forEach(sc => {
                            let id = String(sc.id);

                            subSelect.append(`<option value="${id}">${sc.name}</option>`);

                            currentCategoryOptionIds.push(id);

                            if (!subCatMetaById[id]) {
                                subCatMetaById[id] = {
                                    id: sc.id,
                                    name: sc.name,
                                    categoryId: parseInt(categoryId)
                                };
                            }
                        });

                        subSelect.selectpicker('destroy').selectpicker('render');

                        // Restore or clear selection
                        if (restoreSelection) {
                            let validSelected = currentCategoryOptionIds.filter(
                                id => selectedSubCatIds.has(id)
                            );
                            subSelect.selectpicker('val', validSelected);
                        } else {
                            subSelect.selectpicker('val', []);
                        }

                        subSelect.selectpicker('destroy').selectpicker('render');

                        // Optional (if you use tags)
                        if (typeof renderTags === "function") {
                            renderTags();
                        }
                    },
                    error: function () {
                        toastr.error('Failed to load sub-categories');
                    }
                });
            }

            $(document).on('change', '#BannerMobileSubCategory', function () {
                LoadProducts();
            });

            function LoadProducts() {

                let categoryId     = $('#BannerMobileCategory').val();
                let subCategoryId  = $('#BannerMobileSubCategory').val();
                let productSelect  = $('#BannerMobileProduct');

                productSelect.empty();
                productSelect.append('<option value="">-- Select Product --</option>');

                if (!categoryId || categoryId === "0" || !subCategoryId || subCategoryId === "0") {
                    productSelect.selectpicker('destroy').selectpicker('render');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetProducts", "BannersHomeMobile")',
                    type: 'GET',
                    data: {
                        CategoryId: categoryId,
                        SubCategoryId: subCategoryId
                    },
                    success: function (items) {

                        productSelect.empty();
                        productSelect.append('<option value="">-- Select Product --</option>');

                        (items || []).forEach(p => {
                            productSelect.append(
                                `<option value="${p.productID}">
                                    ${p.productName} - ${p.productGroupName}
                                </option>`
                            );
                        });

                        productSelect.selectpicker('destroy').selectpicker('render');
                    },
                    error: function () {
                        toastr.error('Failed to load products');
                    }
                });
            }

        });
 
    </script>
}