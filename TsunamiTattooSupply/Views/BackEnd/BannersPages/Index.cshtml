            $(document).on("change", "#BannerMobilePresentToggle", function () {

                if ($(this).is(":checked")) {

                    // ✔ Present = TRUE → disable End Date
                    $("#BannerMobileEndDate").prop("disabled", true).val("");

                } else {

                    // ✔ Present = FALSE → enable End Date
                    $("#BannerMobileEndDate").prop("disabled", false);

                }

            });

            const wrapperMobile = document.querySelector("#saveBannerMobileModal .image-box-wrapper");

            if (wrapperMobile) {

                const input       = wrapperMobile.querySelector("#bannerMobileImage");
                const preview     = wrapperMobile.querySelector("#bannerMobileImagePreview");
                const placeholder = wrapperMobile.querySelector(".placeholder-icon");
                const clearBtn    = wrapperMobile.querySelector(".btn-clear-mobile");
                const viewBtn     = wrapperMobile.querySelector(".btn-view-mobile");
                const browseBtn   = wrapperMobile.querySelector(".btn-browse-mobile");

                let dialogOpen = false;

                clearBtn.style.display = "none";
                viewBtn.style.display  = "none";

                function resetBannerMobileImage(clearImageValue = "false") {

                    input.value = "";
                    preview.src = "";
                    preview.classList.add("d-none");
                    placeholder.classList.remove("d-none");

                    clearBtn.style.display = "none";
                    viewBtn.style.display  = "none";

                    $("#ClearImageMobile").val(clearImageValue);
                }

                // =========================
                // Browse Button
                // =========================
                browseBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (dialogOpen) return;

                    dialogOpen = true;

                    setTimeout(() => input.click(), 0);
                });

                // =========================
                // On File Select
                // =========================
                input.addEventListener("change", function () {
                    dialogOpen = false;

                    const file = this.files[0];
                    if (!file) return;

                    const maxSizeKB = 150;
                    const maxSizeBytes = maxSizeKB * 1024;

                    if (file.size > maxSizeBytes) {
                        toastr.error("Image size must not exceed 150 KB");
                        resetBannerMobileImage("false");
                        return;
                    }

                    const reader = new FileReader();

                    reader.onload = function (e) {
                        const img = new Image();

                        img.onload = function () {

                            // 🔥 You can change mobile dimensions if needed
                            const requiredWidth  = 1920;
                            const requiredHeight = 1000;

                            if (img.width !== requiredWidth || img.height !== requiredHeight) {
                                toastr.error("Image dimensions must be exactly 800 x 600 pixels");
                                resetBannerMobileImage("false");
                                return;
                            }

                            preview.src = e.target.result;
                            preview.classList.remove("d-none");
                            placeholder.classList.add("d-none");

                            clearBtn.style.display = "inline-block";
                            viewBtn.style.display  = "inline-block";

                            $("#ClearImageMobile").val("false");
                        };

                        img.src = e.target.result;
                    };

                    reader.readAsDataURL(file);
                });

                // =========================
                // Dialog safety
                // =========================
                input.addEventListener("click", function () {
                    setTimeout(() => dialogOpen = false, 1000);
                });

                // =========================
                // Clear Image
                // =========================
                clearBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    resetBannerMobileImage("true");
                });

                // =========================

                // View Image Modal
                // =========================
                viewBtn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (!preview.src) return;

                    $("#imageBannerMobileViewModalImg").attr("src", preview.src);
                    new bootstrap.Modal(document.getElementById("imageBannerMobileViewModal")).show();
                });
            }
