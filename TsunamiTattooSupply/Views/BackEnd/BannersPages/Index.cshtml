                    render: function (data, type, row) {

                        if (!row.image) {
                            return `<span class="text-muted">No Image</span>`;
                        }

                        return `
                            <img src="${row.imagePath}${row.image}"
                                 style="width:70px;height:70px;object-fit:contain;border-radius:4px;cursor:pointer"
                                 class="bannerImagePreviewMobile"
                                 data-img="${row.image}"
                                 data-imagepath="${row.imagePath}">
                        `;
                    }
                },

                // 🔹 Name (Description)
                {
                    data: "name",
                    className: "align-middle"
                },

                // 🔹 Category
                {
                    data: "categoryDescription",
                    className: "align-middle",
                    render: function (data) {
                        return data ? data : '<span class="text-muted">-</span>';
                    }
                },

                // 🔹 SubCategory
                {
                    data: "subCategoryDescription",
                    className: "align-middle",
                    render: function (data) {
                        return data ? data : '<span class="text-muted">-</span>';
                    }
                },

                // 🔹 Product
                {
                    data: "productDescription",
                    className: "align-middle",
                    render: function (data) {
                        return data ? data : '<span class="text-muted">-</span>';
                    }
                },

                // 🔹 Status
                {
                    data: "status",
                    className: "align-middle text-center",
                    render: function (data, type, row) {
                        return `
                            <div class="badge text-white"
                                 style="background-color:#${row.statusColor}; width:120px;">
                                ${data}
                            </div>
                        `;
                    }
                },

                // 🔹 Actions
                {
                    data: null,
                    orderable: false,
                    searchable: false,
                    className: "no-export text-center align-middle",
                    render: function (data, type, row) {

                        return `
                        <div class="dropdown">
                            <button class="btn btn-sm btn-light" type="button" data-toggle="dropdown">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>

                            <div class="dropdown-menu">

                                <a class="dropdown-item btnEditBannerMobile"
                                   data-id="${row.id}"
                                   data-name="${row.name ?? ''}"
                                   data-image="${row.image ?? ''}"
                                   data-imagepath="${row.imagePath ?? ''}"
                                   data-categoryid="${row.categoryID ?? '0'}"
                                   data-subcategoryid="${row.subCategoryID ?? '0'}"
                                   data-productid="${row.productID ?? '0'}"
                                   data-statusid="${row.statusID}">
                                    <i class="fas fa-edit"></i> Edit
                                </a>

                                <a class="dropdown-item btnDeleteBannerMobile"
                                   data-id="${row.id}">
                                    <i class="fas fa-trash"></i> Delete
                                </a>

                            </div>
                        </div>
                        `;
                    }
                }
            ],

            order: [[1, "asc"]]
        });

            function resetBannerMobileForm() {

                // =========================
                // IDs
                // =========================
                $('#BannerMobileID').val(0);
                $('#BannerMobileTypeID').val('');

                // =========================
                // Inputs
                // =========================
                $('#BannerMobileDescription').val('');

                // =========================
                // Dropdowns (selectpicker)
                // =========================
                $('#BannerMobileCategory')
                    .val(0)
                    .selectpicker('destroy')
                    .selectpicker('render');

                $('#BannerMobileSubCategory')
                    .html('')
                    .selectpicker('destroy')
                    .selectpicker('render');

                $('#BannerMobileProduct')
                    .html('')
                    .selectpicker('refresh')
                    .selectpicker('render');

                // =========================
                // Status
                // =========================
                $('#BannerMobileStatusToggle').prop('checked', true);
                $('#BannerMobileStatusID').val('A');

                // =========================
                // Image Reset
                // =========================
                $('#bannerMobileImage').val('');

                $('#bannerMobileImagePreview')
                    .attr('src', '')
                    .addClass('d-none');

                // show placeholder again
                $('#saveBannerMobileModal .placeholder-icon').removeClass('d-none');

                // reset clear flag
                $('#ClearImageMobile').val('false');

                // =========================
                // Validation Messages
                // =========================
                $('#BannerMobileDescriptionMessage').html('');
                $('#BannerMobileCategoryMessage').html('');
                $('#BannerMobileSubCategoryMessage').html('');
                $('#BannerMobileProductMessage').html('');

                // =========================
                // Modal Title
                // =========================
                $('#modalBannerMobileTitle').text('Create New BannerMobile');

            }

            let currentCategoryOptionIds = [];
            let subCatMetaById = {};

            $(document).on('change', '#BannerMobileCategory', function () {
                LoadSubCategories();
            });

            function LoadSubCategories(restoreSelection = false, selectedSubCatIds = new Set()) {

                let categoryId = $('#BannerMobileCategory').val();
                let subSelect  = $('#BannerMobileSubCategory');

                subSelect.empty();
                currentCategoryOptionIds = [];

                // Default option
                subSelect.append('<option value="">-- Select Sub Category --</option>');

                if (!categoryId || categoryId === "0") {
                    subSelect.selectpicker('destroy').selectpicker('render');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetSubCategories", "BannersHomeMobile")',
                    type: 'GET',
                    data: { categoryId },
                    success: function (items) {

                        (items || []).forEach(sc => {
                            let id = String(sc.id);

                            subSelect.append(`<option value="${id}">${sc.name}</option>`);

                            currentCategoryOptionIds.push(id);

                            if (!subCatMetaById[id]) {
                                subCatMetaById[id] = {
                                    id: sc.id,
                                    name: sc.name,
                                    categoryId: parseInt(categoryId)
                                };
                            }
                        });

                        subSelect.selectpicker('destroy').selectpicker('render');

                        // Restore or clear selection
                        if (restoreSelection) {
                            let validSelected = currentCategoryOptionIds.filter(
                                id => selectedSubCatIds.has(id)
                            );
                            subSelect.selectpicker('val', validSelected);
                        } else {
                            subSelect.selectpicker('val', []);
                        }

                        subSelect.selectpicker('destroy').selectpicker('render');

                        // Optional (if you use tags)
                        if (typeof renderTags === "function") {
                            renderTags();
                        }
                    },
                    error: function () {
                        toastr.error('Failed to load sub-categories');
                    }
                });
            }

            $(document).on('change', '#BannerMobileSubCategory', function () {
                LoadProducts();
            });

            function LoadProducts() {

                let categoryId     = $('#BannerMobileCategory').val();
                let subCategoryId  = $('#BannerMobileSubCategory').val();
                let productSelect  = $('#BannerMobileProduct');

                productSelect.empty();
                productSelect.append('<option value="">-- Select Product --</option>');

                if (!categoryId || categoryId === "0" || !subCategoryId || subCategoryId === "0") {
                    productSelect.selectpicker('destroy').selectpicker('render');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetProducts", "BannersHomeMobile")',
                    type: 'GET',
                    data: {
                        CategoryId: categoryId,
                        SubCategoryId: subCategoryId
                    },
                    success: function (items) {

                        productSelect.empty();
                        productSelect.append('<option value="">-- Select Product --</option>');

                        (items || []).forEach(p => {
                            productSelect.append(
                                `<option value="${p.productID}">
                                    ${p.productName} - ${p.productGroupName}
                                </option>`
                            );
                        });

                        productSelect.selectpicker('destroy').selectpicker('render');
                    },
                    error: function () {
                        toastr.error('Failed to load products');
                    }
                });
            }

            $(document).on("click", "#btnSaveBannerMobile", function (e) {

                e.preventDefault();

                let btn     = $(this);
                let spinner = $("#btnSaveBannerMobileSpinner");

                let id            = $("#BannerMobileID").val();
                let description   = $("#BannerMobileDescription").val().trim();
                let statusId      = $("#BannerMobileStatusID").val();

                let categoryId    = $("#BannerMobileCategory").val();
                let subCategoryId = $("#BannerMobileSubCategory").val();
                let productId     = $("#BannerMobileProduct").val();

                let imageFile     = $("#bannerMobileImage")[0].files[0];
                let clearImage    = $("#ClearImageMobile").val();
                let pageLocationId = $("#BannerLocationPage").val();

                let isValid = true;

                // =========================
                // Reset messages
                // =========================
                $("#BannerMobileDescriptionMessage").html("");
                $("#BannerMobileCategoryMessage").html("");
                $("#BannerMobileSubCategoryMessage").html("");
                $("#BannerMobileProductMessage").html("");

                // =========================
                // Validation
                // =========================
                if (description === "") {
                    $("#BannerMobileDescriptionMessage").html("Description is required");
                    isValid = false;
                }

                if (!categoryId || categoryId === "0") {
                    $("#BannerMobileCategoryMessage").html("Category is required");
                    isValid = false;
                }

                if (!subCategoryId || subCategoryId === "0") {
                    $("#BannerMobileSubCategoryMessage").html("Sub Category is required");
                    isValid = false;
                }

                if (!productId || productId === "0") {
                    $("#BannerMobileProductMessage").html("Product is required");
                    isValid = false;
                }

                if (id === "0" && !imageFile) {
                    toastr.error("Image is required");
                    isValid = false;
                }

                if (!isValid) return;

                // =========================
                // UI Loading
                // =========================
                spinner.removeClass("d-none");
                btn.prop("disabled", true);

                // =========================
                // FormData
                // =========================
                let formData = new FormData();

                formData.append("ID", id);
                formData.append("Description", description);
                formData.append("StatusID", statusId);
                formData.append("PageLocationID", pageLocationId);

                formData.append("CategoryID", categoryId);
                formData.append("SubCategoryID", subCategoryId);
                formData.append("ProductID", productId);

                formData.append("ClearImageMobile", clearImage);

                if (imageFile) {
                    formData.append("Image", imageFile);
                }

                // =========================
                // AJAX
                // =========================
                $.ajax({
                    url: '@Url.Action("SaveBannerMobile", "BannersPages")',
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,

                    success: function (response) {

                        spinner.addClass("d-none");
                        btn.prop("disabled", false);

                        if (response.success) {

                            toastr.success(response.message);

                            $("#saveBannerMobileModal").modal("hide");

                            // 🔥 reload mobile table
                            $("#tableBannersMobile").DataTable().ajax.reload(null, false);

                        } else {

                            toastr.error(response.message);

                        }
                    },

                    error: function () {

                        spinner.addClass("d-none");
                        btn.prop("disabled", false);

                        toastr.error("Something went wrong");

                    }
                });

            });

        });
  
    </script>
}