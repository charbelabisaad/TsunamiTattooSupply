			}
		});
	});

$(document).on("click", "#btnSaveProductStock", function () {

	let btn = $("#btnSaveProductStock");
	let spinner = $("#btnSaveProductStockSpinner");

	if (btn.data("loading")) return;
	btn.data("loading", true);

	// =========================================
	// DUPLICATE BARCODE CHECK
	// =========================================
	let barcodeMap = {};
	let duplicateError = false;

	$(".barcode").each(function () {

		let input = $(this);
		let value = input.val().trim();

		input.removeClass("border-danger");

		if (!value) return;

		if (barcodeMap[value]) {
			input.addClass("border-danger");
			barcodeMap[value].addClass("border-danger");
			duplicateError = true;
		} else {
			barcodeMap[value] = input;
		}

	});

	if (duplicateError) {
		toastr.error("Duplicate barcode exists in table");
		btn.data("loading", false);
		return;
	}

	// =========================================
	// PREPARE DATA
	// =========================================
	btn.prop("disabled", true);
	spinner.removeClass("d-none");

	let formData = new FormData();
	formData.append("ProductID", $("#ProductID").val());

	let index = 0;

	let stockMap = {};

	$("#ProductStock tbody tr").each(function () {

		let row = $(this);

		let stockId = row.find(".stock-id").val() || 0;
		let sizeId = row.find(".size-id").val();
		let colorId = row.find(".color-id").selectpicker('val');
		let typeId = row.find(".type-id").selectpicker('val') || 0;
		let detailId = row.find(".detail-id").selectpicker('val') || 0;
		let qty = row.find(".qty").val() || 0;
		let barcode = row.find(".barcode").val() || "";
		let stockInUse = row.find(".useinstock").is(':checked') ? 1 : 0;

		// ===============================
		// COLOR VALIDATION
		// ===============================
		if (!colorId) {

			let input = row.find(".color-id");

			input.addClass("border-danger");

			toastr.error("Please select a color");

			$('html,body').animate({
				scrollTop: input.offset().top - 150
			}, 400);

			btn.prop("disabled", false);
			spinner.addClass("d-none");
			btn.data("loading", false);

			duplicateError = true;
			return false;
		}

		// ===============================
		// DUPLICATE STOCK CHECK
		// ===============================
		let key = `${sizeId}_${colorId}_${typeId}_${detailId}`;

		row.removeClass("table-danger");

		if (stockMap[key]) {

			row.addClass("table-danger");

			toastr.error("Stock already exists for this combination");

			btn.prop("disabled", false);
			spinner.addClass("d-none");
			btn.data("loading", false);

			duplicateError = true;
			return false;
		}

		stockMap[key] = true;

		// ===============================
		// APPEND FORM DATA
		// ===============================
		formData.append(`StockID[${index}]`, stockId);
		formData.append(`StockSizeID[${index}]`, sizeId);
		formData.append(`StockColorID[${index}]`, colorId);
		formData.append(`StockTypeID[${index}]`, typeId);
		formData.append(`StockDetailID[${index}]`, detailId);
		formData.append(`StockQty[${index}]`, qty);
		formData.append(`StockBarcode[${index}]`, barcode);
		formData.append(`StockInUse[${index}]`, stockInUse);

		index++;

	});

	if (duplicateError) {
		toastr.error("Please fix highlighted fields");
		btn.prop("disabled", false);
		spinner.addClass("d-none");
		btn.data("loading", false);
		return;
	}

	// =========================================
	// AJAX SAVE
	// =========================================
	$.ajax({
		url: '@Url.Action("SaveStock", "Products")',
		type: "POST",
		data: formData,
		processData: false,
		contentType: false,

		success: function (res) {

			btn.prop("disabled", false);
			spinner.addClass("d-none");
			btn.data("loading", false);

			if (res.success) {

				toastr.success("Stock saved successfully");

				listProductStock($("#ProductID").val());

			} else {

				toastr.error(res.message || "Error saving");

				if (res.message && res.message.includes("Barcode")) {

					let barcode = res.message.split(":")[1]?.trim();

					$(".barcode").each(function () {

						if ($(this).val() === barcode) {

							$(this).addClass("border-danger");

							$('html,body').animate({
								scrollTop: $(this).offset().top - 150
							}, 400);

						}

					});

				}

			}

		},

		error: function () {

			btn.prop("disabled", false);
			spinner.addClass("d-none");
			btn.data("loading", false);

			toastr.error("Server error while saving");

		}
	});

});


		function listProductStock(productId){
			 
			if (!productId) return;

			$.ajax({
				url: '@Url.Action("GetProductStock", "Products")',
				type: 'GET',
				data: { productId: productId },

				success: function (res) {

					if (!res.success) {
						toastr.error(res.message);
						return;
					}

					window.STOCK_COLORS  = res.colors;
					window.STOCK_TYPES = res.sizeTypes;
					window.STOCK_DETAILS = res.sizeDetails;

					let html = "";

					// =========================================
					// 🔥 GROUP STOCKS BY SIZE
					// =========================================
					let stockMap = {};

					res.stocks.forEach(s => {
						if (!stockMap[s.sizeID]) stockMap[s.sizeID] = [];
						stockMap[s.sizeID].push(s);
					});

					// =========================================
					// 🔥 LOOP SIZES
					// =========================================
					res.productSizes.forEach(size => {

						html += `
							<div class="variation-card mb-3">

								<div class="variation-header p-2 bg-light">
									<span class="text-primary font-weight-bold">
										${size.sizeDescription}
									</span>
									<span class="text-muted">Rank: ${size.sizeRank}</span>
								</div>

								<div class="variation-body p-2">

									<div class="text-right mb-2">
										<button type="button"
												class="btn btn-black btnAddProductStock"
												value="${size.sizeID}">
											<i class="fas fa-plus"></i> Add
										</button>
									</div>

									<table class="table table-sm table-bordered">
										<thead class="bg-light">
											<tr>
												<th style="width:200px">Color</th>
												<th style="width:150px">Type</th>
												<th style="width:150px">Detail</th>
												<th style="width:100px">Qty</th>
												<th style="width:160px">Barcode</th>
												<th style="width:60px">Used</th>
												<th style="width:60px"></th>
											</tr>
										</thead>
										<tbody>
						`;

						let stocks = stockMap[size.sizeID] || [];

						// =========================================
						// 🔥 SORT (OPTIONAL BUT CLEAN)
						// =========================================
						stocks.sort((a, b) => {
							return a.colorName.localeCompare(b.colorName);
						});

						// =========================================
						// 🔥 RENDER STOCK ROWS
						// =========================================
						stocks.forEach(stock => {
							html += buildStockRow(stock);
						});

						html += `
										</tbody>
									</table>
								</div>
							</div>
						`;
					});

					$("#ProductStock").html(html);

					// =========================================
					// 🔥 RE-INIT SELECTPICKER
					// =========================================
					$('#ProductStock .selectpicker').selectpicker('render');
				}
			});

		}
		 
		function AddStockRow(stock = null, sizeID = null) {

			let colorOptions = `<option value="">Select</option>`;

			STOCK_COLORS.forEach(c => {
				colorOptions += `
				<option value="${c.colorID}"
					${stock?.colorID == c.colorID ? 'selected' : ''}>
					${c.name}
				</option>`;
			});

			// =========================================
			// 🔥 UNIQUE TYPES (FIX HERE)
			// =========================================
			const uniqueTypes = [...new Map(
				STOCK_DETAILS.map(t => [t.productTypeID, t])
			).values()];

			let typeOptions = `<option value="">Select</option>`;

			uniqueTypes.forEach(t => {
				typeOptions += `
				<option value="${t.productTypeID}"
					${stock?.productTypeID == t.productTypeID ? 'selected' : ''}>
					${t.productTypeDescription}
				</option>`;
			});

			// =========================================
			// DETAILS (KEEP AS IS)
			// =========================================
			let detailOptions = `<option value="">Select</option>`;

			// 🔥 REMOVE DUPLICATES
			const uniqueDetails = [...new Map(
				STOCK_DETAILS.map(d => [
					`${d.productTypeID}_${d.productDetailID}`, d
				])
			).values()];

			uniqueDetails.forEach(d => {
				detailOptions += `
				<option value="${d.productDetailID}"
					data-type="${d.productTypeID}"
					${stock?.productDetailID == d.productDetailID ? 'selected' : ''}>
					${d.productDetailDescription}
				</option>`;
			});

			return `
			<tr>

				<td style="width:200px">
					<input type="hidden" class="stock-id" value="${stock?.id ?? 0}">
					<input type="hidden" class="size-id" value="${sizeID ?? stock?.sizeID ?? ''}">

					<select class="form-control form-control-sm color-id selectpicker" data-live-search="true">
						${colorOptions}
					</select>
				</td>

				<td style="width:150px">
					<select class="form-control form-control-sm type-id selectpicker" data-live-search="true">
						${typeOptions}
					</select>
				</td>

				<td style="width:150px">
					<select class="form-control form-control-sm detail-id selectpicker" data-live-search="true">
						${detailOptions}
					</select>
				</td>

				<td style="width:100px">
					<input type="number" class="form-control form-control-sm qty"
						   min="0" value="${stock?.quantity ?? 0}">
				</td>

				<td style="width:160px">
					<input type="text" class="form-control form-control-sm barcode"
						   value="${stock?.barcode ?? ''}">
				</td>

				<td style="width:60px" class="align-middle text-center">
					<input type="checkbox" class="useinstock"
						   ${stock?.useInStock ? 'checked' : ''}>
				</td>

				<td style="width:60px" class="align-middle text-center">
					<button type="button" class="btn btn-sm btn-danger remove-row">
						<i class="fas fa-trash"></i>
					</button>
				</td>

			</tr>`;
		}

		$(document).on('changed.bs.select', '.type-id', function () {

		const $row = $(this).closest('tr');
		const typeId = $(this).val();
		const $detail = $row.find('.detail-id');

		// 🔥 RESET selection
		$detail.selectpicker('val', []);

		// 🔥 SHOW / HIDE OPTIONS INSTEAD OF REBUILD
		$detail.find('option').each(function () {

			let optionType = $(this).data('type');

			if (!optionType || optionType == typeId) {
				$(this).show();
			} else {
				$(this).hide();
			}
		});

		// 🔥 REFRESH UI
		$detail.selectpicker('render');
	});

			// 🔥 trigger on change
			$(document).on('changed.bs.select', '.selectpicker', function () {
				renderSelectTags(this);
			});

			// 🔥 trigger on load
			$('.selectpicker').each(function () {
				renderSelectTags(this);
			});



	});


</script>
