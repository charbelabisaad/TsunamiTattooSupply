					@* 			</div> *@
								 
					@* 		</div> *@

					@* 	</div> *@

					@* </div> *@


                </div>

				 
                <!-- ✅ Fixed footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-ban"></i> Cancel
                    </button>
                    <button id="btnSaveProduct" type="button" class="btn btn-primary">
                        <span class="spinner-border spinner-border-sm d-none" id="btnSaveProductSpinner" role="status" aria-hidden="true"></span>
                        <i class="fas fa-save"></i> Save
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', function () {


	$('#ProductSizes').on('changed.bs.select', function () {

		let container = $('#SizeVariationsContainer');
		let selectedOptions = $(this).find('option:selected');

		// Clear container
		container.empty();

		selectedOptions.each(function () {

			let sizeId = $(this).val();
			let sizeText = $(this).text();

			let html = `
				<div class="variation-card" data-size-id="${sizeId}">

					<div class="variation-header p-2">
						<span>${sizeText}</span>

						<div class="custom-control custom-switch">
							<input type="checkbox"
								   class="custom-control-input"
								   id="SizeStatus_${sizeId}"
								   name="Variations[${sizeId}].IsActive"
								   checked>
							<label class="custom-control-label" for="SizeStatus_${sizeId}">
								Active
							</label>
						</div>
					</div>

					<div class="variation-body p-2">
						<div class="row">
							<div class="col-md-6 mb-3">
								<label>Sale</label>
								<input type="number"
									   step="0.01"
									   class="form-control"
									   name="Variations[${sizeId}].Sale"
									   placeholder="0.00">
							</div>

							<div class="col-md-6 mb-3">
								<label>Raise</label>
								<input type="number"
									   step="0.01"
									   class="form-control"
									   name="Variations[${sizeId}].Raise"
									   placeholder="0.00">
							</div>
						</div>

						<div class="row mt-3">
						
							<div class="col-12 col-md-12">

							@foreach(var obj in Model.currencies){

								<text>
								
									<div>@obj.Code</div>

								</text>

							}

							</div>
						
						</div>

					</div>

				</div>
			`;

			container.append(html);
		});
	});



	});

</script>