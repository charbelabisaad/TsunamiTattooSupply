@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Brands";
}

<style>
    /* 🔹 Dark translucent backdrop for both modals */
    #imageBrandViewModal,
    #imageSubBrandViewModal {
        background-color: rgba(0, 0, 0, 0.88);
        backdrop-filter: blur(4px); /* subtle blur for elegance */
        z-index: 5000;
    }

        /* 🔹 Center modal content beautifully */
        #imageBrandViewModal .modal-dialog,
        #imageSubBrandViewModal .modal-dialog {
            max-width: 500px;
            max-height: 500px;
            margin: auto;
        }

        /* 🔹 Transparent modal box */
        #imageBrandViewModal .modal-content,
        #imageSubBrandViewModal .modal-content {
            background: transparent;
            border: none;
            box-shadow: none;
        }

        /* 🔹 Smooth image transitions */
        #imageBrandViewModal img,
        #imageSubBrandViewModal img {
            transition: transform 0.25s ease-in-out, opacity 0.25s ease-in-out;
            opacity: 0.95;
        }

            /* 🔹 Slight zoom and fade on hover */
            #imageBrandViewModal img:hover,
            #imageSubBrandViewModal img:hover {
                transform: scale(1.1);
                opacity: 1;
            }

        /* 🔹 Optional close button hover effect */
        #imageBrandViewModal .btn:hover,
        #imageSubBrandViewModal .btn:hover {
            background: rgba(255, 255, 255, 0.2) !important;
            transform: scale(1.1);
            transition: all 0.2s ease-in-out;
        }

    /* 🔹 Orange bordered SubBrand button */
    .btnViewSubBrands {
        border: 1px solid #ff6600 !important;
        color: #ff6600 !important;
        width: 130px;
        transition: all 0.2s ease-in-out;
    }

        .btnViewSubBrands:hover {
            background-color: #ff6600 !important;
            color: #ffffff !important;
        }

        .btnViewSubBrands:focus {
            box-shadow: none !important;
        }

    /* 🔹 Equal-height header style for SubBrand cards */
    .subcardheader-equal {
        min-height: 56px; /* ensures consistent header height */
        padding: 0.75rem 1rem !important; /* consistent spacing inside */
        align-brands: center; /* vertical center */
        justify-content: space-between; /* title on left, button on right */
    }
</style>

<partial name="SaveBrand" />
<partial name="DeleteBrand" />

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div><!-- /.col -->
            </div><!-- /.row -->
        </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col-6 d-flex align-brands-center"><h3 class="card-title">Brands List</h3></div>
                        <div class="col-6 d-flex align-brands-center justify-content-end">
                            <button id="btnNewBrand" type="button" class="btn btn-sm btn-black"><i class="fas fa-plus"></i> Add New Brand</button>
                        </div>
                    </div>

                </div>

                <div class="card-body p-0">

                    <div class="col-sm-12 mt-3">
                        <table id="tableBrands" class="table table-striped w-100 ">
                            <thead>
                                <tr style="vertical-align:middle">
                                    <th style="width:70px">Image</th>        <!-- NEW -->
                                    <th style="width:70%">Description</th>
                                    <th style="width:20%">Status</th> 
                                    <th style="width:100px" class="no-export">Actions</th>
                                </tr>
                            </thead>
                        </table>
                    </div>

                </div>

            </div>

        </div>
    </section>

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

            var table = $('#tableBrands').DataTable({
                processing: true,
                responsive: true,
                ajax: {
                    url: '@Url.Action("ListGetBrands", "Brands")',
                    type: 'GET',
                    dataSrc: function (json) {

                        if (json && json.success === false) {
                            toastr.error(json.message || "Failed to load brands.");
                            return [];
                        }

                        if (!json || !json.data) {
                            toastr.error("Unexpected response from server.");
                            return [];
                        }

                        return json.data;
                    }
                },

                // SAME DOM layout as Categories
                dom:
                    '<"row mb-2"<"col-md-6"f><"col-md-6 text-right"B>>t' +
                    '<"row mt-2 mb-2 d-flex align-items-center"' +
                    '<"col-md-6 d-flex align-items-center" l>' +
                    '<"col-md-4 d-flex align-items-center justify-content-end" i>' +
                    '<"col-md-2 d-flex justify-content-end" p>' +
                    '>',


                language: {
                    search: "",
                    searchPlaceholder: "Search brands..."
                },

                buttons: [
                    {
                        extend: 'copy',
                        className: 'btn btn-secondary btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-copy"></i> Copy'
                    },
                    {
                        extend: 'excel',
                        className: 'btn btn-success btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-file-excel"></i> Excel'
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn btn-danger btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-file-pdf"></i> PDF',
                        customize: function (doc) {
                            var tableBody = doc.content[1].table.body;
                            var colCount = tableBody[0].length;

                            var colWidths = [];
                            for (var i = 0; i < colCount; i++) colWidths.push('*');

                            doc.content[1].table.widths = colWidths;
                            doc.styles.tableBodyEven.alignment = 'center';
                            doc.styles.tableBodyOdd.alignment = 'center';
                            doc.styles.tableHeader.alignment = 'center';
                            doc.defaultStyle.fontSize = 8;
                            doc.pageMargins = [10, 10, 10, 10];
                        }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-dark btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-print"></i> Print'
                    },
                    {
                        text: '<i class="fas fa-sync"></i> Refresh',
                        className: 'btn btn-primary btn-sm',
                        action: function () {
                            table.ajax.reload();
                        }
                    }
                ],

                order: [[2, 'asc']], // Order by Status (same logic as categories)

                columns: [
                    // 🔹 Brand Image
                    {
                        data: "image",
                        className: "align-middle",
                        render: function (data, type, row) {
                            if (!row.image)
                                return `<span class="text-muted">No Image</span>`;

                            return `
                                <img src="/images/brands/${row.image}"
                                     style="width:70px;height:70px;object-fit:contain;border-radius:4px;cursor:pointer"
                                     class="brandImagePreview"
                                     data-img="${row.image}">
                            `;
                        }
                    },

                    // 🔹 Brand Description
                    {
                        data: "name",
                        className: "align-middle"
                    },

                    // 🔹 Brand Status with Color Badge
                    {
                        data: "status",
                        className: "align-middle text-center",
                        render: function (data, type, row) {
                            return `
                                <div class="badge text-white"
                                     style="background-color:#${row.statusColor}; width:100px;">
                                    ${data}
                                </div>
                            `;
                        }
                    },

                    // 🔹 Actions
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        className: "no-export text-center align-middle",
                        render: function (data, type, row) {
                            return `
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light" type="button" data-toggle="dropdown">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item btnEditBrand"
                                       data-id="${row.id}"
                                       data-name="${row.name}"
                                       data-image="${row.image}"
                                       data-statusid="${row.statusID}">
                                       <i class="fas fa-edit"></i> Edit
                                    </a>

                                    <a class="dropdown-item btnDeleteBrand"
                                       data-id="${row.id}">
                                       <i class="fas fa-trash"></i> Delete
                                    </a>
                                </div>
                            </div>
                            `;
                        }
                    }
                ]
            });


            // OPTIONAL: add style to search
            var $filter = $('#tableBrands_filter');
            $filter.css("position", "relative");

            $(document).on("click", "#btnNewBrand", function () {

                // Reset fields
                $("#BrandID").val(0);
                $("#BrandDescription").val("");
                $("#BrandDescriptionMessage").html("");

                // Reset Status Toggle
                $("#BrandStatusToggle").prop("checked", true);
                $("#BrandStatusLabel").text("Active");
                $("#BrandStatusID").val("A");

                // Reset Image
                $("#brandImagePreview").attr("src", "").addClass("d-none");
                $("#brandImage").val(""); // clear file input
                $(".placeholder-icon").removeClass("d-none");

                $("#ClearImage").val("false");

                // Set Modal Title
                $("#modalBrandTitle").text("Create New Brand");

                // Open modal
                $("#saveBrandModal").modal("show");
            });

            // 🔹 Status Toggle
            $(document).on("change", "#BrandStatusToggle", function () {
                $("#BrandStatusID").val(this.checked ? "A" : "I");
                $("#BrandStatusLabel").text(this.checked ? "Active" : "Inactive");
            });

            // 🔹 Show Home Toggle
            $(document).on("change", "#BrandShowHomeToggle", function () {
                $("#BrandShowHome").val(this.checked ? "1" : "0");
            });

            $(function () {
                $("#brandDetails").summernote({
                    height: 230,
                    disableResizeEditor: true
                });
            });

        });

    </script>

}