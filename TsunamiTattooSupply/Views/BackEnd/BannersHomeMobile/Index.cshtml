                                       data-subcategoryid="${row.subCategoryID ?? '0'}"
                                       data-groupid="${row.groupID ?? '0'}"
                                       data-productid="${row.productID ?? '0'}"
                                       data-shopnow="${row.shopNow}"
                                       data-statusid="${row.statusID}">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>

                                    <a class="dropdown-item btnDeleteBanner" style="cursor:pointer"
                                       data-id="${row.id}">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>
                                </div>
                            </div>
                            `;
                        }
                    }
                ],
                order: [[1, "asc"]]
            });

