@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Banners";
}

<style>
    /* 🔹 Dark translucent backdrop for both modals */
    #imageBannerViewModal,
    #imageSubBannerViewModal {
        background-color: rgba(0, 0, 0, 0.88);
        backdrop-filter: blur(4px); /* subtle blur for elegance */
        z-index: 5000;
    }

        /* 🔹 Center modal content beautifully */
        #imageBannerViewModal .modal-dialog,
        #imageSubBannerViewModal .modal-dialog {
            max-width: 500px;
            max-height: 500px;
            margin: auto;
        }

        /* 🔹 Transparent modal box */
        #imageBannerViewModal .modal-content,
        #imageSubBannerViewModal .modal-content {
            background: transparent;
            border: none;
            box-shadow: none;
        }

        /* 🔹 Smooth image transitions */
        #imageBannerViewModal img,
        #imageSubBannerViewModal img {
            transition: transform 0.25s ease-in-out, opacity 0.25s ease-in-out;
            opacity: 0.95;
        }

            /* 🔹 Slight zoom and fade on hover */
            #imageBannerViewModal img:hover,
            #imageSubBannerViewModal img:hover {
                transform: scale(1.1);
                opacity: 1;
            }

        /* 🔹 Optional close button hover effect */
        #imageBannerViewModal .btn:hover,
        #imageSubBannerViewModal .btn:hover {
            background: rgba(255, 255, 255, 0.2) !important;
            transform: scale(1.1);
            transition: all 0.2s ease-in-out;
        }

    /* 🔹 Orange bordered SubBanner button */
    .btnViewSubBanners {
        border: 1px solid #ff6600 !important;
        color: #ff6600 !important;
        width: 130px;
        transition: all 0.2s ease-in-out;
    }

        .btnViewSubBanners:hover {
            background-color: #ff6600 !important;
            color: #ffffff !important;
        }

        .btnViewSubBanners:focus {
            box-shadow: none !important;
        }

    /* 🔹 Equal-height header style for SubBanner cards */
    .subcardheader-equal {
        min-height: 56px; /* ensures consistent header height */
        padding: 0.75rem 1rem !important; /* consistent spacing inside */
        align-groups: center; /* vertical center */
        justify-content: space-between; /* title on left, button on right */
    }
     

</style>

<partial name="SaveBanner" />
<partial name="DeleteBanner" />
<partial name="Rank" />

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div><!-- /.col -->
            </div><!-- /.row -->
        </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col-6 d-flex align-groups-center"><h3 class="card-title">Banners List</h3></div>
                        <div class="col-6 d-flex align-groups-center justify-content-end">
                            <button id="btnNewBanner" type="button" class="btn btn-sm btn-black"><i class="fas fa-plus"></i> Add New Banner</button>
                            <button id="btnSetRankBanner" type="button" class="btn btn-sm btn-primary btn-rank ml-3 d-none"><i class="fa-solid fa-arrow-down-1-9"></i> Set Rank</button>
                        </div>
                    </div>

                </div>

                <div class="card-body p-0">
                    <div class="col-sm-12 mt-3">

                        <table id="tableBanners" class="table table-striped w-100">
                            <thead>
                                <tr style="vertical-align:middle">
                                    <th style="width:80px">Image</th>
                                    <th style="width:18%">Description</th>
                                    <th style="width:12%">Category</th>
                                    <th style="width:12%">SubCategory</th>
                                    <th style="width:12%">Group</th>
                                    <th style="width:12%">Product</th>
                                    <th style="width:8%">Shop Now</th>
                                    <th style="width:8%">Status</th>
                                    <th style="width:6%" class="no-export">Actions</th>
                                </tr>
                            </thead>
                        </table>
                            
                    </div>
                </div>

            </div>

        </div>
    </section>

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

           const wrapper = document.querySelector(".image-box-wrapper");

        if (wrapper) {
            const input = wrapper.querySelector("#bannerImage");
            const preview = wrapper.querySelector("#bannerImagePreview");
            const placeholder = wrapper.querySelector(".placeholder-icon");
            const clearBtn = wrapper.querySelector(".btn-clear");
            const viewBtn = wrapper.querySelector(".btn-view");
            const browseBtn = wrapper.querySelector(".btn-browse");

            clearBtn.style.display = "none";
            viewBtn.style.display = "none";

            function resetBannerImage(clearImageValue = "false") {
                input.value = "";
                preview.src = "";
                preview.classList.add("d-none");
                placeholder.classList.remove("d-none");

                clearBtn.style.display = "none";
                viewBtn.style.display = "none";

                $("#ClearImage").val(clearImageValue);
            }

            // remove old handlers first
            $(browseBtn).off("click");
            $(input).off("change");
            $(clearBtn).off("click");
            $(viewBtn).off("click");

            $(browseBtn).on("click", function (e) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();

                input.click();
            });

            $(input).on("change", function () {
                const file = this.files[0];
                if (!file) return;

                const maxSizeKB = 100;
                const maxSizeBytes = maxSizeKB * 1024;

                if (file.size > maxSizeBytes) {
                    toastr.error("Image size must not exceed 100 KB");
                    resetBannerImage("false");
                    return;
                }

                const reader = new FileReader();

                reader.onload = function (e) {
                    const img = new Image();

                    img.onload = function () {
                        const requiredWidth = 1080;
                        const requiredHeight = 563;

                        if (img.width !== requiredWidth || img.height !== requiredHeight) {
                            toastr.error("Image dimensions must be exactly 1080 x 563 pixels");
                            resetBannerImage("false");
                            return;
                        }

                        preview.src = e.target.result;
                        preview.classList.remove("d-none");
                        placeholder.classList.add("d-none");

                        clearBtn.style.display = "inline-block";
                        viewBtn.style.display = "inline-block";

                        $("#ClearImage").val("false");
                    };

                    img.src = e.target.result;
                };

                reader.readAsDataURL(file);
            });

            $(clearBtn).on("click", function (e) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();

                resetBannerImage("true");
            });

            $(viewBtn).on("click", function (e) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();

                if (!preview.src) return;

                $("#imageBannerViewModalImg").attr("src", preview.src);
                new bootstrap.Modal(document.getElementById("imageBannerViewModal")).show();
            });
        }

