        $(document).on('change', 'input[name="BannerLink"]', function () {
            toggleBannerLink(this.id);
        });

        $(document).ready(function () {
            toggleBannerLink($('input[name="BannerLink"]:checked').attr('id'));
        });

        function toggleBannerLink(radioId) {

            const map = {
                BannerCategoryRadio: '#BannerCategory',
                BannerSubCategoryRadio: '#BannerSubCategory',
                BannerGroupRadio: '#BannerGroup', 
                BannerProductRadio: '#BannerProduct'
            };

           

            // disable all
            $('#BannerCategory, #BannerSubCategory, #BannerGroup, #BannerProduct')
                .prop('disabled', true);

            if(!$('#BannerShopNow').is(':checked')){ 

                // enable selected
                if (map[radioId]) {
                    $(map[radioId]).prop('disabled', false);
                }
             
                // 🔥 refresh AFTER all changes
                $('#BannerCategory').selectpicker('destroy').selectpicker('render');
                $('#BannerSubCategory').selectpicker('destroy').selectpicker('render');
                $('#BannerGroup').selectpicker('destroy').selectpicker('render');
                $('#BannerProduct').selectpicker('destroy').selectpicker('render');

            }

        }

        // ================================
        // 🔹 SAVE BANNER BUTTON
        // ================================
        $("#btnSaveBanner").on("click", function (e) {
            e.preventDefault();

            $("#BannerDescriptionMessage").text("");
            $("#BannerCategoryMessage").text("");
            $("#BannerSubCategoryMessage").text("");
            $("#BannerProductMessage").text("");

            let isValid = true;

            let id = $("#BannerID").val() || 0;
            let description = $("#BannerDescription").val().trim();
            let categoryId = $("#BannerCategory").val();
            let subCategoryId = $("#BannerSubCategory").val();
            let groupId = $("#BannerGroup").val();
            let productId = $("#BannerProduct").val();
            let shopNow = $("#BannerShopNowRadio").prop("checked");
            let imageFile = $("#bannerImage")[0].files[0];
            let bannerLink = $('input[name="BannerLink"]:checked').attr('id');
             
            if (description === "") {
                $("#BannerDescriptionMessage").text("Description is required");
                isValid = false;
            }

            if (bannerLink === 'BannerCategoryRadio') {
                if (!categoryId || categoryId === "0") {
                    $("#BannerCategoryMessage").text("Category is required");
                    isValid = false;
                }
            }
            else if (bannerLink === 'BannerSubCategoryRadio') {
                if (!subCategoryId || subCategoryId === "0") {
                    $("#BannerSubCategoryMessage").text("Sub Category is required");
                    isValid = false;
                }
            }
            else if (bannerLink === 'BannerGroupRadio') {
                if (!groupId || groupId === "0") {
                    $("#BannerGroupMessage").text("Group is required");
                    isValid = false;
                }
            }
            else if (bannerLink === 'BannerProductRadio') {
                if (!productId || productId === "0") {
                    $("#BannerProductMessage").text("Product is required");
                    isValid = false;
                }
            }

            // image required only when create
            if (id == 0 && !imageFile) {
                toastr.error("Image is required");
                isValid = false;
            }

            if (!isValid) return;

            let btn = $("#btnSaveBanner");
            let spinner = $("#btnSaveBannerSpinner");

            btn.prop("disabled", true);
            spinner.removeClass("d-none");

            let formData = new FormData();
            formData.append("ID", id);
            formData.append("Description", description);
            formData.append("CategoryID", categoryId);
            formData.append("GroupID", groupId);
            formData.append("SubCategoryID", subCategoryId);
            formData.append("ProductID", productId);
            formData.append("ShopNow",shopNow);
            formData.append("StatusID", $("#BannerStatusID").val());
            formData.append("ClearImage", $("#ClearImage").val());

            formData.append("BannerLink", bannerLink);

            if (imageFile) {
                formData.append("Image", imageFile);
            }


            $.ajax({
                url: '@Url.Action("SaveBanner", "BannersHomeMobile")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    btn.prop("disabled", false);
                    spinner.addClass("d-none");

                    if (response.success) {
                        toastr.success(response.message);

                        $("#saveBannerModal").modal("hide");

                        // $("#bannerForm")[0].reset();
                        // $("#BannerID").val(0);
                        // $("#BannerTypeID").val("");
                        // $("#BannerStatusID").val("A");
                        // $("#ClearImage").val("false");

                        // $("#BannerCategory").val("0"); 
 
                        // $("#bannerImage").val("");
                        // $("#bannerImagePreview").attr("src", "").addClass("d-none");
                        // $(".placeholder-icon").removeClass("d-none");
                        // $(".btn-clear").hide();
                        // $(".btn-view").hide();

                        if ($.fn.DataTable.isDataTable("#tableBanners")) {
                            $("#tableBanners").DataTable().ajax.reload(null, false);
                        }
                    } else {
                        toastr.error(response.message || "Failed to save mobile banner");
                    }
                },
                error: function (xhr) {
                    btn.prop("disabled", false);
                    spinner.addClass("d-none");

                    let message = "An error occurred while saving mobile banner";

                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        message = xhr.responseJSON.message;
                    }

                    toastr.error(message);
                }
            });
        });



            // ========================
            // Status Toggle
            // ========================
            $("#BannerStatusToggle").on("change", function () {
                if (this.checked) {
                    $("#BannerStatusID").val("A");
                    $(this).next("label").text("Active");
                } else {
                    $("#BannerStatusID").val("I");
                    $(this).next("label").text("Inactive");
                }
            });

            // ============================================
            // IMAGE UPLOAD / PREVIEW / CLEAR / VIEW
            // ============================================

      

        // ================================
        // 🔹 OPEN DELETE MODAL
        // ================================
        $(document).on("click", ".btnDeleteBanner", function () {
            let id = $(this).data("id");

            $("#deletedBannerId").val(id);
            $("#deleteBannerMessage").text("Are you sure you want to delete this Banner?");
            $("#deleteBannerModal").modal("show");

        });

              // ================================
            // 🔹 CONFIRM DELETE BANNER
            // ================================
            $(document).on("click", "#btnConfirmDeleteBanner", function () {

                let id = $("#deletedBannerId").val();

                $("#btnDeleteSpinner").removeClass("d-none");
                $("#btnConfirmDeleteBanner i").addClass("d-none");
                $("#btnConfirmDeleteBanner").prop("disabled", true);

                $.ajax({
                    url: '@Url.Action("DeleteBanner","BannersHomeMobile")',

                    type: "POST",
                    data: { ID: id },
                    success: function (response) {

                        if (response.success) {
                            toastr.success(response.message);

                            $("#deleteBannerModal").modal("hide");

                            if ($.fn.DataTable.isDataTable("#tableBanners")) {
                                $("#tableBanners").DataTable().ajax.reload(null, false);
                            }
                        } else {
                            toastr.error(response.message || "Failed to delete banner.");
                        }

                        resetDeleteButton();
                    },
                    error: function () {
                        toastr.error("Server error while deleting banner.");
                        resetDeleteButton();
                    }
                });

                function resetDeleteButton() {
                    $("#btnDeleteSpinner").addClass("d-none");
                    $("#btnConfirmDeleteBanner i").removeClass("d-none");
                    $("#btnConfirmDeleteBanner").prop("disabled", false);
                }
            });

