@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Banners";
}

<style>
    /* 🔹 Dark translucent backdrop for both modals */
    #imageBannerViewModal,
    #imageSubBannerViewModal {
        background-color: rgba(0, 0, 0, 0.88);
        backdrop-filter: blur(4px); /* subtle blur for elegance */
        z-index: 5000;
    }

        /* 🔹 Center modal content beautifully */
        #imageBannerViewModal .modal-dialog,
        #imageSubBannerViewModal .modal-dialog {
            max-width: 500px;
            max-height: 500px;
            margin: auto;
        }

        /* 🔹 Transparent modal box */
        #imageBannerViewModal .modal-content,
        #imageSubBannerViewModal .modal-content {
            background: transparent;
            border: none;
            box-shadow: none;
        }

        /* 🔹 Smooth image transitions */
        #imageBannerViewModal img,
        #imageSubBannerViewModal img {
            transition: transform 0.25s ease-in-out, opacity 0.25s ease-in-out;
            opacity: 0.95;
        }

            /* 🔹 Slight zoom and fade on hover */
            #imageBannerViewModal img:hover,
            #imageSubBannerViewModal img:hover {
                transform: scale(1.1);
                opacity: 1;
            }

        /* 🔹 Optional close button hover effect */
        #imageBannerViewModal .btn:hover,
        #imageSubBannerViewModal .btn:hover {
            background: rgba(255, 255, 255, 0.2) !important;
            transform: scale(1.1);
            transition: all 0.2s ease-in-out;
        }

    /* 🔹 Orange bordered SubBanner button */
    .btnViewSubBanners {
        border: 1px solid #ff6600 !important;
        color: #ff6600 !important;
        width: 130px;
        transition: all 0.2s ease-in-out;
    }

        .btnViewSubBanners:hover {
            background-color: #ff6600 !important;
            color: #ffffff !important;
        }

        .btnViewSubBanners:focus {
            box-shadow: none !important;
        }

    /* 🔹 Equal-height header style for SubBanner cards */
    .subcardheader-equal {
        min-height: 56px; /* ensures consistent header height */
        padding: 0.75rem 1rem !important; /* consistent spacing inside */
        align-groups: center; /* vertical center */
        justify-content: space-between; /* title on left, button on right */
    }
     
</style>

<partial name="SaveBanner" />
<partial name="DeleteBanner" />
<partial name="Rank" />

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div><!-- /.col -->
            </div><!-- /.row -->
        </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col-6 d-flex align-groups-center"><h3 class="card-title">Banners List</h3></div>
                        <div class="col-6 d-flex align-groups-center justify-content-end">
                            <button id="btnNewBanner" type="button" class="btn btn-sm btn-black"><i class="fas fa-plus"></i> Add New Banner</button>
                            <button id="btnSetRankBanner" type="button" class="btn btn-sm btn-primary btn-rank ml-3"><i class="fa-solid fa-arrow-down-1-9"></i> Set Rank</button>
                        </div>
                    </div> 
                </div>

                <div class="card-body p-0">
                    <div class="col-sm-12 mt-3">
    
                        <table id="tableBanners" class="table table-striped w-100">
                            <thead>
                                <tr style="vertical-align:middle">
                                    <th style="width:100px">Image</th>
                                    <th style="width:200px">Description</th>
                                    <th>Sentence</th>
                                    <th>Link</th>
                                    <th class="d-none"></th>
                                    <th style="width:50px">Status</th>
                                    <th style="width:50px" class="no-export">Actions</th>
                                </tr>
                            </thead>
                        </table>
                            
                    </div>
                </div>

            </div>

        </div>
    </section>

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

        const wrapper = document.querySelector(".image-box-wrapper");

        if (wrapper) {

            const input = wrapper.querySelector("#bannerImage");
            const preview = wrapper.querySelector("#bannerImagePreview");
            const placeholder = wrapper.querySelector(".placeholder-icon");
            const clearBtn = wrapper.querySelector(".btn-clear");
            const viewBtn = wrapper.querySelector(".btn-view");
            const browseBtn = wrapper.querySelector(".btn-browse");

            let dialogOpen = false;

            clearBtn.style.display = "none";
            viewBtn.style.display = "none";

            function resetBannerImage(clearImageValue = "false") {
                input.value = "";
                preview.src = "";
                preview.classList.add("d-none");
                placeholder.classList.remove("d-none");

                clearBtn.style.display = "none";
                viewBtn.style.display = "none";

                $("#ClearImage").val(clearImageValue);
            }

            // Browse Button
            browseBtn.addEventListener("click", function (e) {
                e.preventDefault();
                e.stopPropagation();

                if (dialogOpen) return;

                dialogOpen = true;

                setTimeout(function () {
                    input.click();
                }, 0);
            });

            // On File Select
            input.addEventListener("change", function () {
                dialogOpen = false;

                const file = this.files[0];
                if (!file) return;

                const maxSizeKB = 150;
                const maxSizeBytes = maxSizeKB * 1024;

                if (file.size > maxSizeBytes) {
                    toastr.error("Image size must not exceed 150 KB");
                    resetBannerImage("false");
                    return;
                }

                const reader = new FileReader();

                reader.onload = function (e) {
                    const img = new Image();

                    img.onload = function () {
                        const requiredWidth = 1920;
                        const requiredHeight = 768;

                        if (img.width !== requiredWidth || img.height !== requiredHeight) {
                            toastr.error("Image dimensions must be exactly 1920 x 768 pixels");
                            resetBannerImage("false");
                            return;
                        }

                        preview.src = e.target.result;
                        preview.classList.remove("d-none");
                        placeholder.classList.add("d-none");

                        clearBtn.style.display = "inline-block";
                        viewBtn.style.display = "inline-block";

                        $("#ClearImage").val("false");
                    };

                    img.src = e.target.result;
                };

                reader.readAsDataURL(file);
            });

            // If dialog closes without file selection
            input.addEventListener("click", function () {
                setTimeout(function () {
                    dialogOpen = false;
                }, 1000);
            });

            // Clear Image
            clearBtn.addEventListener("click", function (e) {
                e.preventDefault();
                e.stopPropagation();

                resetBannerImage("true");
            });

            // View Image Modal
            viewBtn.addEventListener("click", function (e) {
                e.preventDefault();
                e.stopPropagation();

                if (!preview.src) return;

                $("#imageBannerViewModalImg").attr("src", preview.src);
                new bootstrap.Modal(document.getElementById("imageBannerViewModal")).show();
            });
        }

            var table = $('#tableBanners').DataTable({
                processing: true,
                responsive: true,
                ajax: {
                    url: '@Url.Action("ListGetBanners","BannersHomeWeb")',
                    type: 'GET',
                    dataSrc: function (json) {
                        if (json && json.success === false) {
                            toastr.error(json.message || "Failed to load banners.");
                            return [];
                        }
                        if (!json || !json.data) {
                            toastr.error("Unexpected response from server.");
                            return [];
                        }
                        return json.data;
                    }
                },

                dom:
                    '<"row mb-2"<"col-md-6"f><"col-md-6 text-right"B>>t' +
                    '<"row mt-2 mb-2 d-flex align-items-center"' +
                    '<"col-md-6 d-flex align-items-center" l>' +
                    '<"col-md-4 d-flex align-items-center justify-content-end" i>' +
                    '<"col-md-2 d-flex justify-content-end" p>' +
                    '>',


                language: {
                    search: "",
                    searchPlaceholder: "Search banners..."
                },

                buttons: [
                    {
                        extend: 'copy',
                        className: 'btn btn-secondary btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-copy"></i> Copy'
                    },
                    {
                        extend: 'excel',
                        className: 'btn btn-success btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-file-excel"></i> Excel'
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn btn-danger btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-file-pdf"></i> PDF',
                        customize: function (doc) {
                            var tableBody = doc.content[1].table.body;
                            var colCount = tableBody[0].length;

                            var colWidths = [];
                            for (var i = 0; i < colCount; i++) colWidths.push('*');

                            doc.content[1].table.widths = colWidths;
                            doc.styles.tableBodyEven.alignment = 'center';
                            doc.styles.tableBodyOdd.alignment = 'center';
                            doc.styles.tableHeader.alignment = 'center';
                            doc.defaultStyle.fontSize = 8;
                            doc.pageMargins = [10, 10, 10, 10];
                        }
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-dark btn-sm',
                        exportOptions: { columns: ':visible:not(.no-export)' },
                        text: '<i class="fas fa-print"></i> Print'
                    },
                    {
                        text: '<i class="fas fa-sync"></i> Refresh',
                        className: 'btn btn-primary btn-sm',
                        action: function () {
                            table.ajax.reload();
                        }
                    }
                ],

                columns: [
                    {
                        data: "image",
                        className: "align-middle",
                        render: function (data, type, row) {
                            if (!row.image) {
                                return `<span class="text-muted">No Image</span>`;
                            }

                            return `<img src="${row.imagePath}${row.image}"
                                         style="width:70px;height:70px;object-fit:contain;border-radius:4px;cursor:pointer"
                                         class="bannerImagePreview"
                                         data-img="${row.image}"
                                         data-imagepath="${row.imagePath}">`;
                        }
                    },
                    {
                        data: "description",
                        className: "align-middle"
                    },
                    {
                        data: "sentence",
                        className: "align-middle",
                        render: function (data) {
                            return data ? data : '<span class="text-muted">-</span>';
                        }
                    },
                    {
                        data: "link",
                        className: "align-middle",
                        render: function (data) {
                            if (!data) {
                                return '<span class="text-muted">-</span>';
                            }

                            return `<a href="${data}" target="_blank">${data}</a>`;
                        }
                    },

                    {
                        data: "rank",
                        className: "align-middle",
                        visible: false
                    },
                       // 🔹 Group Status with Color Badge
                    {
                        data: "status",
                        className: "align-middle text-center",
                        render: function (data, type, row) {
                            return `
                                <div class="badge text-white"
                                        style="background-color:#${row.statusColor}; width:120px;">
                                    ${data}
                                </div>
                            `;
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        className: "no-export text-center align-middle",
                        render: function (data, type, row) {
                            return `
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light" type="button" data-toggle="dropdown">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item btnEditBanner" style="cursor:pointer"
                                       data-id="${row.id}"
                                       data-description="${row.description ?? ''}"
                                       data-sentence="${row.sentence ?? ''}"
                                       data-link="${row.link ?? ''}"
                                       data-imagepath="${row.imagePath ?? ''}"
                                       data-image="${row.image ?? ''}"
                                       data-statusid="${row.statusID}">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>

                                    <a class="dropdown-item btnDeleteBanner" style="cursor:pointer"
                                       data-id="${row.id}">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>
                                </div>
                            </div>
                            `;
                        }
                    }
                ],
                order: [[4, "asc"]]
            });

            $("#btnNewBanner").on("click", function () {

                // Title
                $("#modalBannerTitle").text("Create New Banner");

                // Reset hidden fields
                $("#BannerID").val(0);
                $("#BannerTypeID").val("");

                // Reset text fields
                $("#BannerDescription").val("");
                $("#groupDetails").val("");

                // Reset validation messages
                $("#BannerDescriptionMessage").html("");

                // Reset status
                $("#BannerStatusToggle").prop("checked", true);
                $("#BannerStatusID").val("A");
                $("label[for='BannerStatusToggle']").text("Active");

                // Reset image
                $("#groupImage").val("");
                $("#groupImagePreview").attr("src", "").addClass("d-none");
                $(".placeholder-icon").removeClass("d-none");
                $(".btn-clear").hide();
                $(".btn-view").hide();
                $("#ClearImage").val("false");

                // If using Summernote
                if ($("#groupDetails").hasClass("summernote")) {
                    $("#groupDetails").summernote("code", "");
                } else {
                    $("#groupDetails").val("");
                }

                // Open modal
                $("#saveBannerModal").modal("show");
            });

        $(document).on("click", ".btnEditBanner", function () {

            let id = $(this).data("id");
            let description = $(this).data("description");
            let sentence = $(this).data("sentence");
            let link = $(this).data("link");
            let imagePath = $(this).data("imagepath");
            let image = $(this).data("image");
            let statusId = $(this).data("statusid");

            $("#modalBannerTitle").text("Edit Banner");

            $("#BannerID").val(id);
            $("#BannerDescription").val(description);
            $("#BannerSentence").val(sentence);
            $("#BannerLink").val(link);
            $("#BannerStatusID").val(statusId);
            $("#ClearImage").val("false");

            if (statusId === "A") {
                $("#BannerStatusToggle").prop("checked", true);
                $("#BannerStatusToggle").next("label").text("Active");
            } else {
                $("#BannerStatusToggle").prop("checked", false);
                $("#BannerStatusToggle").next("label").text("Inactive");
            }

            $("#BannerDescriptionMessage").text("");
            $("#BannerSentenceMessage").text("");
            $("#BannerLinkMessage").text("");

            const preview = $("#bannerImagePreview");
            const placeholder = $(".placeholder-icon");
            const clearBtn = $(".btn-clear");
            const viewBtn = $(".btn-view");
            const input = $("#bannerImage");

            input.val("");

            if (image && imagePath) {
                preview.attr("src", imagePath + image).removeClass("d-none");
                placeholder.addClass("d-none");
                clearBtn.show();
                viewBtn.show();
            } else {
                preview.attr("src", "").addClass("d-none");
                placeholder.removeClass("d-none");
                clearBtn.hide();
                viewBtn.hide();
            }

            $("#saveBannerModal").modal("show");
        });

          

             // ================================
        // 🔹 SAVE BANNER BUTTON
        // ================================
        $("#btnSaveBanner").on("click", function (e) {
            e.preventDefault();

            $("#BannerDescriptionMessage").text("");
            $("#BannerSentenceMessage").text("");
            $("#BannerLinkMessage").text("");

            let isValid = true;

            let id = $("#BannerID").val() || 0;
            let description = $("#BannerDescription").val().trim();
            let imageFile = $("#bannerImage")[0].files[0];
            let previewSrc = $("#bannerImagePreview").attr("src");

            if (description === "") {
                $("#BannerDescriptionMessage").text("Description is required");
                isValid = false;
            }

            // image required only when create
            if ((id == 0) && !imageFile) {
                toastr.error("Image is required");
                isValid = false;
            }

            if (!isValid) return;

            let btn = $("#btnSaveBanner");
            let spinner = $("#btnSaveBannerSpinner");

            btn.prop("disabled", true);
            spinner.removeClass("d-none");

            let formData = new FormData();
            formData.append("ID", id);
            formData.append("Description", description);
            formData.append("Sentence", $("#BannerSentence").val().trim());
            formData.append("Link", $("#BannerLink").val().trim());
            formData.append("StatusID", $("#BannerStatusID").val());
            formData.append("ClearImage", $("#ClearImage").val());

            if (imageFile) {
                formData.append("Image", imageFile);
            }

            $.ajax({ 
                url: '@Url.Action("SaveBanner", "BannersHomeWeb")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    btn.prop("disabled", false);
                    spinner.addClass("d-none");

                    if (response.success) {
                        toastr.success(response.message);

                        $("#saveBannerModal").modal("hide");

                        // reset form after save
                        $("#bannerForm")[0].reset();
                        $("#BannerID").val(0);
                        $("#BannerStatusID").val("A");
                        $("#ClearImage").val("false");

                        $("#bannerImage").val("");
                        $("#bannerImagePreview").attr("src", "").addClass("d-none");
                        $(".placeholder-icon").removeClass("d-none");
                        $(".btn-clear").hide();
                        $(".btn-view").hide();

                        // reload datatable if exists
                        if ($.fn.DataTable.isDataTable("#tableBanners")) {
                            $("#tableBanners").DataTable().ajax.reload(null, false);
                        }
                    } else {
                        toastr.error(response.message || "Failed to save banner");
                    }
                },
                error: function (xhr) {
                    btn.prop("disabled", false);
                    spinner.addClass("d-none");

                    let message = "An error occurred while saving banner";

                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        message = xhr.responseJSON.message;
                    }

                    toastr.error(message);
                }
            });
        });

        // ============================================
        // 🔹 IMAGE UPLOAD / PREVIEW / CLEAR / VIEW
        // ============================================
             // ========================
        // Status Toggle
        // ========================
        $("#BannerStatusToggle").on("change", function () {
            if (this.checked) {
                $("#BannerStatusID").val("A");
                $(this).next("label").text("Active");
            } else {
                $("#BannerStatusID").val("I");
                $(this).next("label").text("Inactive");
            }
        });

         

        // ================================
        // 🔹 OPEN DELETE MODAL
        // ================================
        $(document).on("click", ".btnDeleteBanner", function () {
            let id = $(this).data("id");

            $("#deletedBannerId").val(id);
            $("#deleteBannerMessage").text("Are you sure you want to delete this Banner?");
            $("#deleteBannerModal").modal("show");
        });

              // ================================
            // 🔹 CONFIRM DELETE BANNER
            // ================================
            $(document).on("click", "#btnConfirmDeleteBanner", function () {

                let id = $("#deletedBannerId").val();

                $("#btnDeleteSpinner").removeClass("d-none");
                $("#btnConfirmDeleteBanner i").addClass("d-none");
                $("#btnConfirmDeleteBanner").prop("disabled", true);

                $.ajax({
                    url: '@Url.Action("DeleteBanner","BannersHomeWeb")',

                    type: "POST",
                    data: { ID: id },
                    success: function (response) {

                        if (response.success) {
                            toastr.success(response.message);

                            $("#deleteBannerModal").modal("hide");

                            if ($.fn.DataTable.isDataTable("#tableBanners")) {
                                $("#tableBanners").DataTable().ajax.reload(null, false);
                            }
                        } else {
                            toastr.error(response.message || "Failed to delete banner.");
                        }

                        resetDeleteButton();
                    },
                    error: function () {
                        toastr.error("Server error while deleting banner.");
                        resetDeleteButton();
                    }
                });

                function resetDeleteButton() {
                    $("#btnDeleteSpinner").addClass("d-none");
                    $("#btnConfirmDeleteBanner i").removeClass("d-none");
                    $("#btnConfirmDeleteBanner").prop("disabled", false);
                }
            });

            $(document).on('click', '#btnSetRankBanner', function () {

                const $rankSelect = $('#rankSelect');

                $rankSelect.empty();

                $("#rankMode").val("BNRHMWB")

                $.ajax({
                    url: '@Url.Action("ListGetBanners", "BannersHomeWeb")',
                    type: 'GET',
                    success: function (res) {

                        if (!res.success) {
                            toastr.error(res.message || 'Failed to load banners');
                            return;
                        }

                        // sort by Rank (safe)
                        res.data.sort((a, b) => a.rank - b.rank);

                        $.each(res.data, function (index, item) {
                            $rankSelect.append(
                                `<option value="${item.id}">
                                    ${index + 1}. ${item.description}
                                </option>`
                            );
                        });

                        $('#rankModal').modal('show');
                    },
                    error: function () {
                        toastr.error('Server error while loading banner');
                    }
                });

            });

        });
         
    </script>

}