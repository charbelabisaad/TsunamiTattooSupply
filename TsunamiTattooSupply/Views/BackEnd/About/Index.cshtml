    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "About";
}

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div><!-- /.col -->
            </div><!-- /.row -->
        </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <div id="cardAbout" class="card">

                <div id="cardAboutHeader" class="card-header font-weight-bold">About</div>

                <div id="cardAboutBody" class="card-body">

                    <input id="AboutID" type="hidden" value="ABT" />

                    <div>

                        <label class="fw-semibold" for="aboutShortDetails">Short Details</label>

                        <textarea id="aboutShortDetails" class="editornote">

                            @if (Model.about != null)
                            {
                                @Model.about.ShortText
                            }
                         
                        </textarea>

                    </div>

                    <div class="mt-3">

                        <label class="fw-semibold" for="aboutLongDetails">Long Details</label>

                        <textarea id="aboutLongDetails" class="editornote">

                            @if (Model.about != null)
                            {
                                @Model.about.LongText
                            }

                        </textarea>

                    </div>
                </div>

                <div id="cardAboutFooter" class="card-footer align-items-center justify-content-end text-right">

                    <button id="btnSaveAbout" type="button" class="btn btn-primary" style="width:100px">
                        <span class="spinner-border spinner-border-sm d-none" id="btnSaveAboutSpinner" role="status" aria-hidden="true"></span>
                        <i class="fas fa-save"></i> Save
                    </button>

                </div>

            </div>

        </div>
    </section>

</div>

@section Scripts {

    <script>

        $(document).ready(function(){

            $('#aboutShortDetails').summernote({

                height:400,
                minHeight:400,
                placeholder:'Write details here...'

            })


            $('#aboutLongDetails').summernote({

                height:400,
                minHeight:400,
                placeholder:'Write details here...'

            })

            // save / load about
            $('#btnSaveAbout').on('click', function () {

                const aboutId = $('#AboutID').val();
                const aboutShortDetails = $('#aboutShortDetails').summernote('code');
                const aboutLongDetails = $('#aboutLongDetails').summernote('code');

                // UI loading state
                $('#btnSaveAboutSpinner').removeClass('d-none');
                $('#btnSaveAbout').prop('disabled', true);
              
                $.ajax({
                    url: '@Url.Action("SaveAbout", "About")',
                    type: 'POST',
                        data: { ID: aboutId, ShortText: aboutShortDetails, LongText: aboutLongDetails },
                    success: function (res) {

                        if(res.success == true)
                            toastr.success(res.message);
                        else
                            toastr.error("Error saving abouts!");
                    },
                    error: function () {
                        toastr.error('Server error while loading about');
                    },
                    complete: function () {
                        // restore UI
                        $('#btnSaveAboutSpinner').addClass('d-none');
                        $('#btnSaveAbout').prop('disabled', false);
                    }
                });
            });

        });

    </script>

}