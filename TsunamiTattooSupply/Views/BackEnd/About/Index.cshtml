@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "About";
}

<div class="modal fade" id="imageAboutViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">

            <div class="modal-body d-flex justify-content-center align-items-center p-0"
                 style="background: rgba(0,0,0,0.9); border-radius: 10px;">

                <img id="imageAboutViewModalImg"
                     src=""
                     class="img-fluid rounded shadow-lg"
                     style="object-fit: contain; border-radius: 10px;" />

                <!-- Close Button -->
                <button type="button"
                        class="btn position-absolute top-0 end-0 m-3"
                        data-bs-dismiss="modal"
                        aria-label="Close"
                        style="background: rgba(0,0,0,0.6); border-radius: 50%; width: 45px; height: 45px;">
                    <i class="fas fa-times text-white fs-4"></i>
                </button>

            </div>
        </div>
    </div>
</div>

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div><!-- /.col -->
            </div><!-- /.row -->
        </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <div id="cardAbout" class="card">

                <div id="cardAboutHeader" class="card-header font-weight-bold">About</div>

                <div id="cardAboutBody" class="card-body">
                     
                    <div class="row">

                        <div class="col-12 col-md-6">

                            <div class="subcard">

                                <div class="subcardheader">Short Details 1</div>
                                 
                                <div class="subcardcontent">

                                    <textarea id="aboutShortDetails1" class="editornote">

                                            @if (Model.about != null)
                                            {
                                                @Model.about.ShortText1
                                            }

                                    </textarea>

                                </div>

                            </div>

                        </div>

                        <div class="col-12 col-md-6">
                             
                            <div class="subcard">

                                <div class="subcardheader">
                                    Image 1
                                </div>

                                <div class="subcardcontent d-flex justify-content-center align-items-center" style="min-height:500px">

                                    <div class="image-box-wrapper mx-auto position-relative"
                                         style="width:400px; height:400px;">

                                        <!-- Main Box -->
                                        <div class="image-box border rounded d-flex align-items-center justify-content-center bg-light position-relative"
                                             style="width:100%; height:100%; cursor:pointer;">

                                            <input type="file"
                                                   id="aboutImage1"
                                                   accept="image/*"
                                                   style="opacity:0; position:absolute; width:100%; height:100%; cursor:pointer;" />

                                            <span class="text-muted placeholder-icon" style="font-size:50px;">
                                                <i class="fas fa-image"></i>
                                            </span>

                                            <img id="aboutImagePreview1"
                                                 class="img-fluid rounded d-none"
                                                 style="width:100%; height:100%; object-fit:contain;" />
                                        </div>

                                        <!-- Overlay Buttons -->
                                        <div class="image-overlay d-flex flex-column justify-content-center align-items-center">
                                            <div class="d-flex gap-4">
                                                <button type="button" class="overlay-btn btn-clear1" title="Clear">
                                                    <i class="fas fa-times"></i>
                                                </button>

                                                <button type="button" class="overlay-btn btn-view1" title="View">
                                                    <i class="fas fa-eye"></i>
                                                </button>

                                                <button type="button" class="overlay-btn btn-browse1" title="Browse">
                                                    <i class="fas fa-paperclip"></i>
                                                </button>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                            </div>
 
                        </div>

                    </div>
                     
                    <div class="row">

                        <div class="col-12 col-md-6">

                            <div class="subcard">

                                <div class="subcardheader">Short Details 2</div>

                                <div class="subcardcontent">
                                     
                                    <textarea id="aboutShortDetails2" class="editornote">

                                        @if (Model.about != null)
                                        {
                                            @Model.about.ShortText2
                                        }

                                    </textarea>
                                     
                                </div>

                            </div>
                             
                        </div>

                        <div class="col-12 col-md-6">

                            <div class="subcard">

                                <div class="subcardheader">
                                    Image 2
                                </div>

                                <div class="subcardcontent d-flex justify-content-center align-items-center" style="min-height:500px">

                                    <div class="image-box-wrapper mx-auto position-relative"
                                         style="width:400px; height:400px;">

                                        <!-- Main Box -->
                                        <div class="image-box border rounded d-flex align-items-center justify-content-center bg-light position-relative"
                                             style="width:100%; height:100%; cursor:pointer;">

                                            <input type="file"
                                                   id="aboutImage2"
                                                   accept="image/*"
                                                   style="opacity:0; position:absolute; width:100%; height:100%; cursor:pointer;" />

                                            <span class="text-muted placeholder-icon" style="font-size:50px;">
                                                <i class="fas fa-image"></i>
                                            </span>

                                            <img id="aboutImagePreview2"
                                                 class="img-fluid rounded d-none"
                                                 style="width:100%; height:100%; object-fit:contain;" />
                                        </div>

                                        <!-- Overlay Buttons -->
                                        <div class="image-overlay d-flex flex-column justify-content-center align-items-center">
                                            <div class="d-flex gap-4">
                                                <button type="button" class="overlay-btn btn-clear2" title="Clear">
                                                    <i class="fas fa-times"></i>
                                                </button>

                                                <button type="button" class="overlay-btn btn-view2" title="View">
                                                    <i class="fas fa-eye"></i>
                                                </button>

                                                <button type="button" class="overlay-btn btn-browse2" title="Browse">
                                                    <i class="fas fa-paperclip"></i>
                                                </button>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                            </div>

                        </div>

                    </div>

                  
                    <div class="mt-3">

                        <label class="fw-semibold" for="aboutLongDetails">Long Details</label>

                        <textarea id="aboutLongDetails" class="editornote">

                            @if (Model.about != null)
                            {
                                @Model.about.LongText
                            }

                        </textarea>

                    </div>
                </div>

                <div id="cardAboutFooter" class="card-footer align-items-center justify-content-end text-right">

                    <button id="btnSaveAbout" type="button" class="btn btn-primary" style="width:100px">
                        <span class="spinner-border spinner-border-sm d-none" id="btnSaveAboutSpinner" role="status" aria-hidden="true"></span>
                        <i class="fas fa-save"></i> Save
                    </button>

                </div>

            </div>

        </div>
    </section>

</div>

@section Scripts {

    <script>

        $(document).ready(function(){

                $('#aboutShortDetails1').summernote({

                    height:400,
                    minHeight:400,
                    placeholder:'Write details here...'

                })

                $('#aboutShortDetails2').summernote({

                    height:400,
                    minHeight:400,
                    placeholder:'Write details here...'

                })


                $('#aboutLongDetails').summernote({

                    height:400,
                    minHeight:400,
                    placeholder:'Write details here...'

                })

        @if (Model.about != null)
        {
            <text>

                if ('@Model.about.Image1' !== '') {

                    $('#aboutImagePreview1')
                        .attr('src', '@(Model.about.ImagePath + Model.about.Image1)')
                        .removeClass('d-none');

                    $('#aboutImagePreview1')
                        .closest('.image-box')
                        .find('.placeholder-icon')
                        .addClass('d-none');
                }

                if ('@Model.about.Image2' !== '') {

                    $('#aboutImagePreview2')
                        .attr('src', '@(Model.about.ImagePath + Model.about.Image2)')
                        .removeClass('d-none');

                    $('#aboutImagePreview2')
                        .closest('.image-box')
                        .find('.placeholder-icon')
                        .addClass('d-none');
                }

            </text>
        }

                     let clearImage1 = false;
        let clearImage2 = false;

        // save / load about
        $('#btnSaveAbout').on('click', function () {
             
            const aboutShortDetails1 = $('#aboutShortDetails1').summernote('code');
            const aboutShortDetails2 = $('#aboutShortDetails2').summernote('code');
            const aboutLongDetails = $('#aboutLongDetails').summernote('code');

            // Remove HTML tags and spaces to validate Summernote content
            const shortText1Value = $('<div>').html(aboutShortDetails1).text().trim();
            const shortText2Value = $('<div>').html(aboutShortDetails2).text().trim();
            const longTextValue = $('<div>').html(aboutLongDetails).text().trim();

            if (shortText1Value === '') {
                toastr.error('Short Details 1 is required');
                return;
            }

            if (shortText2Value === '') {
                toastr.error('Short Details 2 is required');
                return;
            }

            if (longTextValue === '') {
                toastr.error('Long Details is required');
                return;
            }

            const formData = new FormData();

         
            formData.append('ShortText1', aboutShortDetails1);
            formData.append('ShortText2', aboutShortDetails2);
            formData.append('LongText', aboutLongDetails);

            formData.append('ClearImage1', clearImage1);
            formData.append('ClearImage2', clearImage2);

            if ($('#aboutImage1')[0].files.length > 0) {
                formData.append('Image1', $('#aboutImage1')[0].files[0]);
            }

            if ($('#aboutImage2')[0].files.length > 0) {
                formData.append('Image2', $('#aboutImage2')[0].files[0]);
            }

            // UI loading state
            $('#btnSaveAboutSpinner').removeClass('d-none');
            $('#btnSaveAbout').prop('disabled', true);

            $.ajax({
                url: '@Url.Action("SaveAbout", "About")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {

                    if (res.success === true) {

                        toastr.success(res.message);

                        clearImage1 = false;
                        clearImage2 = false;

                    } else {
                        toastr.error(res.message || 'Error saving about!');
                    }
                },
                error: function (xhr) {
                    toastr.error('Server error while saving about');
                    console.log(xhr.responseText);
                },
                complete: function () {
                    $('#btnSaveAboutSpinner').addClass('d-none');
                    $('#btnSaveAbout').prop('disabled', false);
                }
            });
        });

                        //////////////////////////////////////////////////////
            // IMAGE 1
            //////////////////////////////////////////////////////

            // Browse
            $(document).on('click', '.btn-browse1', function () {
                $('#aboutImage1').trigger('click');
            });

            // Preview selected image
        $('#aboutImage1').on('change', function () {

            const file = this.files[0];

            if (!file) return;

            const maxSizeKB = 150;
            const maxSizeBytes = maxSizeKB * 1024;

            if (file.size > maxSizeBytes) {

                setTimeout(function () {
                    toastr.error('Image 1 size must not exceed 150 KB');
                }, 100);

                $('#aboutImage1').val('');

                return;
            }

            const reader = new FileReader();

            reader.onload = function (e) {
                $('#aboutImagePreview1')
                    .attr('src', e.target.result)
                    .removeClass('d-none');

                $('#aboutImagePreview1')
                    .closest('.image-box')
                    .find('.placeholder-icon')
                    .addClass('d-none');
            };

            reader.readAsDataURL(file);
        });

            // View
            $(document).on('click', '.btn-view1', function () {

                const imageSrc = $('#aboutImagePreview1').attr('src');

                if (imageSrc) {

                    $('#imageAboutViewModalImg').attr('src', imageSrc);
                    $('#imageAboutViewModal').modal('show');

                } else {
                    toastr.warning('No image selected');
                }
            });

            // Clear
            $(document).on('click', '.btn-clear1', function () {

                $('#aboutImage1').val('');

                $('#aboutImagePreview1')
                    .attr('src', '')
                    .addClass('d-none');

                $('#aboutImagePreview1')
                    .closest('.image-box')
                    .find('.placeholder-icon')
                    .removeClass('d-none');
            });

            //////////////////////////////////////////////////////
            // IMAGE 2
            //////////////////////////////////////////////////////

            // Browse
            $(document).on('click', '.btn-browse2', function () {
                $('#aboutImage2').trigger('click');
            });

            // Preview selected image
                 $('#aboutImage2').on('change', function () {

            const file = this.files[0];

            if (!file) return;

            const maxSizeKB = 150;
            const maxSizeBytes = maxSizeKB * 1024;

            if (file.size > maxSizeBytes) {

                setTimeout(function () {
                    toastr.error('Image 2 size must not exceed 150 KB');
                }, 100);

                $('#aboutImage2').val('');

                return;
            }

            const reader = new FileReader();

            reader.onload = function (e) {
                $('#aboutImagePreview2')
                    .attr('src', e.target.result)
                    .removeClass('d-none');

                $('#aboutImagePreview2')
                    .closest('.image-box')
                    .find('.placeholder-icon')
                    .addClass('d-none');
            };

            reader.readAsDataURL(file);
        });

            // View
            $(document).on('click', '.btn-view2', function () {

                const imageSrc = $('#aboutImagePreview2').attr('src');

                if (imageSrc) {

                    $('#imageAboutViewModalImg').attr('src', imageSrc);
                    $('#imageAboutViewModal').modal('show');

                } else {
                    toastr.warning('No image selected');
                }
            });

            // Clear
            $(document).on('click', '.btn-clear2', function () {

                $('#aboutImage2').val('');

                $('#aboutImagePreview2')
                    .attr('src', '')
                    .addClass('d-none');

                $('#aboutImagePreview2')
                    .closest('.image-box')
                    .find('.placeholder-icon')
                    .removeClass('d-none');
            });

        });

    </script>

}