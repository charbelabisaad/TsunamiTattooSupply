@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Colors";
}

<partial name="SaveColor" />
<partial name="DeleteColor" />

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div><!-- /.col -->
            </div><!-- /.row -->
        </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->
    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col-6 d-flex align-items-center"><h3 class="card-title">Colors List</h3></div>
                        <div class="col-6 d-flex align-items-center justify-content-end">
                            <button id="btnNewColor" type="button" class="btn btn-sm btn-black"><i class="fas fa-plus"></i> Add New Color</button>
                        </div>
                    </div>

                </div>

                <div class="card-body p-0">

                    <div class="col-sm-12 mt-3">
                        <table id="tableColors" class="table table-striped w-100 ">
                            <thead>
                                <tr>
                                    <th style="width:70%">Description</th> 
                                    <th style="width:20%">Status</th>
                                    <th style="width:10%" class="no-export">Actions</th>
                                </tr>
                            </thead>
                        </table>

                    </div>

                </div>

            </div>

        </div>
    </section>

</div>

@section Scripts {

    <script>
            $(document).ready(function () {

                var table = $('#tableColors').DataTable({
                    processing: true,
                    responsive: true,
                    ajax: {
                        url: '@Url.Action("ListGetColors", "Colors")',
                            type: 'GET',
                        dataSrc: function (json) {
                        if (json && json.success === false) {
                            toastr.error(json.message || "Failed to load roles.");
                            return [];
                        }
                        if (!json || !json.data) {
                            toastr.error("Unexpected response from server.");
                            return [];
                        }
                        return json.data;
                    }
                    },
                    dom: '<"row mb-2"<"col-md-6"f><"col-md-6 text-right"B>>t<"row mt-2"<"col-md-6"l><"col-md-6 text-right"ip>>',
                    language: {
                        search: "",
                        searchPlaceholder: "Search roles..."
                    },
                    buttons: [
                            { extend: 'copy', className: 'btn btn-secondary btn-sm', exportOptions: { columns: ':visible:not(.no-export)' }, text: '<i class="fas fa-copy"></i> Copy' },
                            { extend: 'excel', className: 'btn btn-success btn-sm', exportOptions: { columns: ':visible:not(.no-export)' }, text: '<i class="fas fa-file-excel"></i> Excel' },
                            {
                                extend: 'pdfHtml5',
                                className: 'btn btn-danger btn-sm',
                                exportOptions: { columns: ':visible:not(.no-export)' },
                                text: '<i class="fas fa-file-pdf"></i> PDF',
                                customize: function (doc) {
                                    // Set all columns to auto width
                                    var tableBody = doc.content[1].table.body;
                                    var colCount = tableBody[0].length;

                                    // Distribute column widths evenly (100% width)
                                    var colWidths = [];
                                    for (var i = 0; i < colCount; i++) {
                                        colWidths.push('*');
                                    }
                                    doc.content[1].table.widths = colWidths;

                                    // Optional: reduce margins and font size to fit better
                                    doc.styles.tableBodyEven.alignment = 'center';
                                    doc.styles.tableBodyOdd.alignment = 'center';
                                    doc.styles.tableHeader.alignment = 'center';
                                    doc.defaultStyle.fontSize = 8;
                                    doc.pageMargins = [10, 10, 10, 10];
                                }
                            },
                            { extend: 'print', className: 'btn btn-dark btn-sm', exportOptions: { columns: ':visible:not(.no-export)' }, text: '<i class="fas fa-print"></i> Print' },
                        { text: '<i class="fas fa-sync"></i> Refresh', className: 'btn btn-primary btn-sm',
                            action: function () {
                                table.ajax.reload();
                            }
                        }
                    ],
                    columns: [
                        { data: 'description' }, 
                        { data: 'status',
                            render: function (data, type, row) { 
                              return `<div class="badge text-center text-white" style="background-color:#${row.statusColor}; width:100px">${data}</div>`;
                            }
                        },
                        {
                            data: null,
                            orderable: false,
                            searchable: false,
                            className: "no-export",
                            render: function (data, type, row) {
                                return `
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light" type="button" data-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item btnEditColor" style="cursor:pointer" data-id="${row.id}" data-description="${row.description}" 
                                    data-statusid="${row.statusID}">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                        <a class="dropdown-item btnDeleteColor" style="cursor:pointer" data-id="${row.id}">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>   
                                </div>
                            </div>
                                `;
                            }
                        }
                    ]
                });

                // place export buttons next to search bar
                //table.buttons().container().appendTo('#tableColors_wrapper .col-md-6:eq(1)');

                var $filter = $('#tableColors_filter');

                $filter.css("position", "relative");

                // Insert FA icons

                // $filter.append('<i class="fas fa-times" id="clearSearch"></i>');

                // Toggle X on typing
                // $('#tableColors_filter input').on("input", function () {
                //     if ($(this).val().length > 0) {
                //         $('#clearSearch').show();
                //     } else {
                //         $('#clearSearch').hide();
                //     }
                // });

                // Clear on X click
                // $('#clearSearch').on("click", function () {
                //     $('#tableColors_filter input').val('');
                //     table.search('').draw();
                //     $(this).hide();
                // });

                const btnNewColor = document.getElementById("btnNewColor");

                btnNewColor.addEventListener("click", function () {

                    const modalEl = document.getElementById("saveColorModal");
                    const modal = new bootstrap.Modal(modalEl);

                    $("#modalColorTitle").text('Create New Color');

                    $("#ColorID").val(0);

                    $("#ColorDescription").val(''); 
                      
                    $("#ColorStatusID").val('A');
                    $("#ColorStatusToggle").prop("checked", true);
                    $("#ColorStatusLabel").text("Active");

                    $("#ColorDescriptionMessage").text(''); 

                    $("#ColorDescription").removeClass('border-danger');
                     
                    modal.show();

                    $(modalEl).on('shown.bs.modal', function () {

                        $("#ColorDescription").focus();

                    });

                });

                $(document).on('click', '.btnEditColor', function(){

                    $("#modalColorTitle").text('Modify Color');
                     
                    const ColorID = $(this).data('id');
                    const ColorDescription = $(this).data('description'); 
                    const ColorStatusID = $(this).data('statusid');
                    const modalEl = document.getElementById("saveColorModal");
                    const modal = new bootstrap.Modal(modalEl);

                    $("#ColorID").val(ColorID);
                    $("#ColorDescription").val(ColorDescription); 
                    $("#ColorStatusID").val(ColorStatusID);

                    $("#DescriptionMessage").text(''); 

                    $("#ColorDescription").removeClass('border-danger'); 
                     
                    $("#ColorStatusToggle").prop("checked", ColorStatusID == 'A' ? true : false);
                    $("#ColorStatusLabel").text(ColorStatusID == 'A' ? 'Active' : 'Inactive');
                      
                    modal.show();
                     
                    $(modalEl).on('shown.bs.modal', function () {

                        $("#ColorDescription").focus();

                    });

                });

            // Show modal when Delete button clicked
            $(document).on("click", ".btnDeleteColor", function (e) {
              e.preventDefault();

              const roleId = $(this).data("id");
                $("#deletedColorId").val(roleId);

              const roledescription = $(this).closest("tr").find("td:first").text();

              $("#deleteColorMessage").html(
                `Are you sure you want to delete <strong>${roledescription}</strong>?`
              );

              $("#deleteColorModal").modal("show");
            });

            
        });

    </script>
}







