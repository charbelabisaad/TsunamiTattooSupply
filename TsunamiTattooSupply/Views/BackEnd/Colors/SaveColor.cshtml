

<div class="modal fade" id="saveColorModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="modalColorTitle" class="modal-title"></h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <form id="roleForm" method="post">
                <div class="modal-body">
                    <div class="row align-items-center mb-3">
                        <input id="ColorID" type="hidden" value="0" />

                        <!-- 🔹 Label -->
                        <div class="col-12 col-md-2 d-flex align-items-center">
                            <label for="ColorDescription" class="form-label mb-0">Description</label>
                        </div>

                        <!-- 🔹 Input -->
                        <div class="col-12 col-md-8 d-flex align-items-center">
                            <div class="w-100">
                                <input type="text" class="form-control" id="ColorDescription" placeholder="Fill Description" />
                                <div id="ColorDescriptionMessage" class="text-danger fw-normal"></div>
                            </div>
                        </div>

                        <!-- 🔹 Status Toggle -->
                        <div class="col-12 col-md-2 d-flex align-items-center justify-content-md-end">
                            <div class="custom-control custom-switch m-0">
                                <input type="checkbox" class="custom-control-input" id="ColorStatusToggle" checked>
                                <label class="custom-control-label" for="ColorStatusToggle" id="ColorStatusLabel">Active</label>
                                <input type="hidden" id="ColorStatusID" name="ColorStatusID" value="A">
                            </div>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <div class="row w-100">
                        <!-- Validation/Error message -->
                        <div id="modalColorMessage" class="col-md-7 d-flex align-items-center text-danger" style="display:none;">
                            <!-- message goes here -->
                        </div>

                        <!-- Buttons -->
                        <div class="col-md-5 d-flex align-items-center justify-content-end">
                            <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">
                                <i class="fas fa-ban"></i> Cancel
                            </button>

                            <button id="btnSaveColor" type="button" class="btn btn-primary ml-2">
                                <span class="spinner-border spinner-border-sm d-none" id="btnSaveColorSpinner" role="status" aria-hidden="true"></span>
                                <i class="fas fa-save"></i> Save
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        const toggle = document.getElementById("ColorStatusToggle");
        const hidden = document.getElementById("ColorStatusID");
        const label = document.getElementById("ColorStatusLabel");

        if (toggle && hidden && label) {
            toggle.addEventListener("change", function () {
                if (toggle.checked) {
                    label.textContent = "Active";
                    hidden.value = "A";
                } else {
                    label.textContent = "Inactive";
                    hidden.value = "I";
                }
            });
        }

        $('#btnSaveColor').on('click', function (e) {

            e.preventDefault(); // ✅ prevent default form submission

            // Reset validation flag
            let requiredValidation = false;

            // Clear previous errors and borders
            $('#ColorDescription').removeClass("border-danger");
            $('#ColorDescriptionMessage').text('');

            // Show spinner while saving
            $('#btnSaveColorSpinner').removeClass('d-none');
            $('#btnSaveColor i').addClass('d-none');

            // Gather form values
            var data = {
                ID: $('#ColorID').val() || 0,
                Description: $('#ColorDescription').val().trim(),
                StatusID: $('#ColorStatusID').val()
            };

            // Basic validation
            if (!data.Description) {
                $('#ColorDescriptionMessage').text("Description is required!");
                $('#ColorDescription').addClass("border-danger");
                requiredValidation = true;
            }

            // Stop if validation failed
            if (requiredValidation) {
                $('#btnSaveColorSpinner').addClass('d-none');
                $('#btnSaveColor i').removeClass('d-none');
                return;
            }

            // ✅ AJAX request
            $.ajax({
                url: '@Url.Action("SaveColor", "Colors")',
                type: 'POST',
                data: data,
                success: function (response) {

                    const table = $("#tableColors").DataTable();

                    $('#btnSaveColorSpinner').addClass('d-none');
                    $('#btnSaveColor i').removeClass('d-none');
                    $('#btnSaveColor').prop('disabled', true);

                    if (response.exists) {
                        $('#ColorDescriptionMessage').text(response.message || "Description already exists!");
                        $('#ColorDescription').addClass("border-danger");
                        toastr.warning(response.message || "Description already exists!");
                        $('#btnSaveColor').prop('disabled', false);
                        return;
                    }

                    if (response.error) {
                        $('#modalColorMessage').text(response.message || "Error saving role.").show();
                        toastr.error(response.message || "Error saving role.");
                        $('#btnSaveColor').prop('disabled', false);
                        return;
                    }

                    if (response.roles) {
                        $('#saveColorModal').modal('hide');
                        table.ajax.reload(null, false);
                        toastr.success("Color saved successfully!");
                    } else {
                        $('#modalColorMessage').text("Unexpected response from server.").show();
                    }

                    $('#btnSaveColorSpinner').addClass('d-none');
                    $('#btnSaveColor i').removeClass('d-none');
                    $('#btnSaveColor').prop('disabled', false);
                },
                error: function (xhr, status, error) {
                    $('#btnSaveColorSpinner').addClass('d-none');
                    $('#btnSaveColor i').removeClass('d-none');
                    $('#btnSaveColor').prop('disabled', false);
                    $('#modalColorMessage').text("An error occurred while saving role" ).show();
                    toastr.error("An error occurred while saving role."); // ✅ fixed missing parenthesis
                }
            });
        });

    });


</script>
