@{
    Layout = "_Layout";
    ViewData["Title"] = "Contact Us";
}

<link rel="stylesheet" href="~/css/Contact.css" asp-append-version="true" />

<div class="contact-banner">

    <div class="about-banner">

        @if (Model.bannercontact != null)
        {
            <img src="@Url.Content(Model.bannercontact.ImagePath + Model.bannercontact.Image)" class="contact-banner-image" />

            <div class="d-inline-block contact-banner-title">@Model.bannercontact.Name</div>

        }

    </div>

</div>

