                        <path d="M114 53.641V60.3175L112.784 68.7838C107.979 91.9718 88.2278 110.488 64.656 113.487C63.2589 113.666 61.6917 113.59 60.342 113.961C58.1335 113.869 55.8663 114.087 53.6634 113.961C5.01656 111.207 -18.0534 51.3858 16.6115 16.7152C51.3795 -18.0585 111.147 4.89816 114 53.641ZM36.4634 27.2053C36.0144 27.2304 35.5404 27.4395 35.1667 27.6959C33.8142 28.6298 30.0831 32.7584 29.2103 34.208C25.0246 41.1577 27.4507 47.7032 30.8333 54.3128C37.6709 67.6743 54.0259 83.0149 68.9783 86.2933C75.4757 87.7178 82.3913 84.8325 86.2591 79.4411C87.4582 77.7713 87.171 77.0632 85.9496 75.5606C84.427 73.6901 77.2352 66.3055 75.4645 65.1207C74.4829 64.4628 73.8834 64.3402 72.7958 64.8698C70.0435 66.2107 66.7418 72.3213 63.5489 72.7646C62.2578 72.943 61.0531 72.8259 59.9098 72.2126C55.3337 69.7567 44.7538 59.3279 42.1242 54.8258C38.6469 48.8713 46.3015 45.8299 49.0762 41.824C49.988 40.5082 49.8402 39.7499 48.8782 38.501C47.3528 36.519 40.267 29.3853 38.3039 27.9273C37.7657 27.5259 37.1717 27.1691 36.4634 27.2081V27.2053Z" fill="url(#paint0_linear_2768_5346)" />
