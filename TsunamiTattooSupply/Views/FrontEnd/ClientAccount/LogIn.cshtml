@{
}



<link rel="stylesheet" href="~/css/LogIn.css" asp-append-version="true" />

<div class="login d-flex align-items-center justify-content-center">
      
    <div id="LogInCard" class="custom-card">

        <div class="text-center"><img src="~/Images/GENERAL/TsunamiTattooSupplyLogo.png" class="custom-card-logo" /></div>

        <div class="custom-card-content">

            <div class="custom-card-header">Login</div>

            <div class="custom-card-body mt-4">

                <div>
                     <input id="LogInEmail" type="text" name="LogInEmail" class="login-input" placeholder="Username@gmail.com" />
                </div>

                <div class="mt-3">
                    <input id="LogInPassword" type="password" name="LogInPassword" class="login-input" placeholder="Password" />
                </div>

                <div class="mt-1">
                    <a id="LogInForgotPassword" href="#" class="login-forgot-password">Forgot Password?</a>
                </div>

                <div class="mt-4">
                    <button id="btnLogIn" type="button" class="btn-orange-gradiant w-100 m-0" value="LGIN">Sign In</button>
                </div>

                <div class="mt-4">
                    <div class="login-or-continue-with">or continue with</div>
                </div>

                <div class="row mt-4">
                    <div class="col-6">
                        <button id="btnLogInGoogle" type="button" class="login-by-social-media w-100" value="LGINGGL">
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <g clip-path="url(#clip0_2768_5511)">
                                    <path d="M16.9087 6.86531H16.221V6.82988H8.53735V10.2448H13.3622C12.6583 12.2327 10.7669 13.6598 8.53735 13.6598C5.7085 13.6598 3.41494 11.3662 3.41494 8.53735C3.41494 5.7085 5.7085 3.41494 8.53735 3.41494C9.84314 3.41494 11.0311 3.90755 11.9356 4.71219L14.3504 2.2974C12.8257 0.876359 10.7861 0 8.53735 0C3.8226 0 0 3.8226 0 8.53735C0 13.2521 3.8226 17.0747 8.53735 17.0747C13.2521 17.0747 17.0747 13.2521 17.0747 8.53735C17.0747 7.96492 17.0158 7.40615 16.9087 6.86531Z" fill="#FFC107" />
                                    <path d="M0.983765 4.56364L3.78871 6.62072C4.54768 4.74165 6.38578 3.41494 8.53676 3.41494C9.84255 3.41494 11.0305 3.90755 11.9351 4.71219L14.3498 2.2974C12.8251 0.876359 10.7855 0 8.53676 0C5.25756 0 2.41377 1.85132 0.983765 4.56364Z" fill="#FF3D00" />
                                    <path d="M8.53751 17.0754C10.7427 17.0754 12.7464 16.2315 14.2614 14.8591L11.6191 12.6232C10.7331 13.2969 9.65055 13.6613 8.53751 13.6604C6.31695 13.6604 4.43147 12.2445 3.72116 10.2686L0.937134 12.4136C2.35007 15.1784 5.21947 17.0754 8.53751 17.0754Z" fill="#4CAF50" />
                                    <path d="M16.9087 6.86551H16.221V6.83008H8.53735V10.245H13.3622C13.0255 11.1911 12.419 12.0179 11.6176 12.6231L11.6189 12.6222L14.2612 14.8582C14.0743 15.0281 17.0747 12.8062 17.0747 8.53755C17.0747 7.96512 17.0158 7.40635 16.9087 6.86551Z" fill="#1976D2" />
                                </g>
                                <defs>
                                    <clipPath id="clip0_2768_5511">
                                        <rect width="17.075" height="17.075" rx="8.5375" fill="white" />
                                    </clipPath>
                                </defs>
                            </svg> 
                        </button>
                    </div>
                    <div class="col-6">
                        <button id="btnLogInFacebook" type="button" class="login-by-social-media w-100" value="LGINFCBK">
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <g clip-path="url(#clip0_2768_5518)">
                                    <path d="M17.075 8.58988C17.075 3.84517 13.2523 -0.000976562 8.5375 -0.000976562C3.82053 9.06251e-05 -0.00213623 3.84517 -0.00213623 8.59095C-0.00213623 12.8778 3.12045 16.4316 7.20138 17.0762V11.0732H5.03499V8.59095H7.20351V6.69669C7.20351 4.54418 8.4788 3.35533 10.4286 3.35533C11.3634 3.35533 12.3399 3.52288 12.3399 3.52288V5.63591H11.2631C10.2034 5.63591 9.87255 6.29863 9.87255 6.97843V8.58988H12.2396L11.8618 11.0722H9.87148V17.0751C13.9524 16.4305 17.075 12.8768 17.075 8.58988Z" fill="#059BE5" />
                                </g>
                                <defs>
                                    <clipPath id="clip0_2768_5518">
                                        <rect width="17.075" height="17.075" rx="8.5375" fill="white" />
                                    </clipPath>
                                </defs>
                            </svg>

                        </button>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <span class="login-have-an-account-yet">Don’t have an account yet? <a asp-area="" asp-controller="ClientAccount" asp-action="SignUp" class="login-register">Register Here</a></span>
                </div>

            </div>

        </div>

    </div>

</div>