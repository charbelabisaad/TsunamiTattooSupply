@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

<link rel="stylesheet" href="~/css/Home.css" asp-append-version="true" />

<div id="carouselExampleCaptions" class="carousel slide" data-bs-ride="carousel" style="position:relative">

    <div class="carousel-indicators">


            @{
                int SlideCount = 0;
            }

            @foreach (var obj in Model.banners)
            {
                <button type="button"
                        data-bs-target="#carouselExampleCaptions"
                        data-bs-slide-to="@SlideCount"
                        class="@(SlideCount == 0 ? "active" : "")"
                        aria-current="@(SlideCount == 0 ? "true" : null)"
                        aria-label="Slide @(SlideCount + 1)">
                </button>

                SlideCount++;
            }
 
    </div>
     

    
    <div class="carousel-inner">

        @{
            SlideCount = 0;
        }

        @foreach(var obj in Model.banners){
            <div class="carousel-item @(SlideCount == 0 ? "active" : "") ">
                <img src="@Url.Content(obj.ImagePath + obj.Image)" class="d-block w-100" alt="banner"> 
            </div>

            SlideCount++;
        }
 
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<div class="home-brand-bar">
    <div class="brand-track">

        @foreach (var obj in Model.groups)
        {
            <div class="home-brand">
                <img src="@Url.Content(obj.ImagePath + obj.Image)"
                     class="home-brand-image"
                     alt="@obj.Name" />
            </div>
        }
 
    </div>
</div>

<script>
    const container = document.querySelector('.home-brand-bar');
    const items = document.querySelectorAll('.home-brand');

    const speed = 0.5;

    // initial positioning (stack from right → left)
    let startX = container.offsetWidth;

    items.forEach(item => {
        item.x = startX;
        item.style.transform = `translateX(${item.x}px)`;

        const style = getComputedStyle(item);
        const margin = parseInt(style.marginLeft) + parseInt(style.marginRight);

        startX += item.offsetWidth + margin;
    });

    function animate() {
        items.forEach(item => {
            item.x -= speed;

            const style = getComputedStyle(item);
            const margin = parseInt(style.marginLeft) + parseInt(style.marginRight);
            const width = item.offsetWidth + margin;

            // if item fully left → move to right (green)
            if (item.x + width < 0) {

                // find rightmost item
                let maxX = 0;
                items.forEach(i => {
                    if (i.x > maxX) maxX = i.x;
                });

                item.x = container.offsetWidth;
            }

            item.style.transform = `translateX(${item.x}px)`;
        });

        requestAnimationFrame(animate);
    }

    animate();
</script>