    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TsunamiTattooSupply.styles.css" asp-append-version="true" />

    <link rel="icon" href="~/Images/GENERAL/favicon32.png" />
    <link rel="icon" href="~/Images/GENERAL/favicon16.png" />

        <!-- 🔥 Open Graph (WhatsApp / Facebook) -->
    <meta property="og:title" content="Tsunami Tattoo Supply" />
    <meta property="og:description" content="Shop premium tattoo supplies." />
    <meta property="og:image" content="https://new.tsunamitattoosupply.com/Images/GENERAL/TsunamiTattooSupplyLogo.png" />
    <meta property="og:url" content="https://new.tsunamitattoosupply.com/" />
    <meta property="og:type" content="website" />

    <!-- 🔥 Optional but recommended -->
    <meta property="og:site_name" content="Tsunami Tattoo Supply" />

    <!-- 🔥 Twitter (also used sometimes by WhatsApp) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Tsunami Tattoo Supply" />
    <meta name="twitter:description" content="Shop premium tattoo supplies" />
    <meta name="twitter:image" content="https://new.tsunamitattoosupply.com/Images/GENERAL/TsunamiTattooSupplyLogo.png" />

</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <header style="min-width:1000px">   

        <div class="header-bar">

            <div class="header-bar-content d-flex align-items-center justify-content-center text-center">

                <span class="header-bar-content-offer">
                    Sign up and get 20% off your first order.
                </span>

                <a id="btnSignUpNow" 
                    class="header-bar-content-signup ms-2">
                    Sign Up Now
                </a>

            </div>

        </div>
             
        <div class="header">
 
            <div class=" d-flex align-items-center flex-nowrap">

                <div class="col-auto" style="width:100px"></div>

                <div class="col-auto text-start" style="width:430px">

                    <div class="row d-flex align-items-center">
                                
                        <div class="col-3" style="width:85px">
                            <div class="d-inline-block">
                                <a asp-area="" asp-controller="Home" asp-action="Index" class=" @((currentController == "Home" && currentAction == "Index") ? "active" : string.Empty)"><img src="~/Images/GENERAL/TsunamiTattooSupplyLogo.png" class="header-logo" alt="Tsunami Tattoo Supply Logo" /></a>
                            </div> 
                        </div>
                        <div class="col-9 d-flex justify-content-center">
                            <div >
                                <a class="header-menu-item" style="margin-left:0px">Shop <i class="fas fa-chevron-down"></i></a>
                                <a class="header-menu-item">About Us</a>
                                <a class="header-menu-item" style="margin-right:0px">Contact Us</a>
                            </div>
                        </div>
                             
                    </div>
                         
                </div>

