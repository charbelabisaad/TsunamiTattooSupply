<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TsunamiTattooSupply</title>
       
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" asp-append-version="true" /> 
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/css/bootstrap-select.min.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/LogIn.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TsunamiTattooSupply.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/plugins/toastr/toastr.css" asp-append-version="true" />

    <link rel="icon" href="~/Images/GENERAL/favicon32.png" />
    <link rel="icon" href="~/Images/GENERAL/favicon16.png" />


        <!-- 🔥 Open Graph (WhatsApp / Facebook) -->
    <meta property="og:title" content="Tsunami Tattoo Supply" />
    <meta property="og:description" content="Shop premium tattoo supplies." />
    <meta property="og:image" content="https://new.tsunamitattoosupply.com/Images/GENERAL/TsunamiTattooSupplyLogo.png" />
    <meta property="og:url" content="https://new.tsunamitattoosupply.com/" />
    <meta property="og:type" content="website" />

    <!-- 🔥 Optional but recommended -->
    <meta property="og:site_name" content="Tsunami Tattoo Supply" />

    <!-- 🔥 Twitter (also used sometimes by WhatsApp) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Tsunami Tattoo Supply" />
    <meta name="twitter:description" content="Shop premium tattoo supplies" />
    <meta name="twitter:image" content="https://new.tsunamitattoosupply.com/Images/GENERAL/TsunamiTattooSupplyLogo.png" />

</head>
<body>

    <partial name="LogIn" />

    @await Component.InvokeAsync("Header")

    @* <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3"> *@
            @*     <div class="container-fluid"> *@
            @*         <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">TsunamiTattooSupply</a> *@
            @*         <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" *@
            @*                 aria-expanded="false" aria-label="Toggle navigation"> *@
            @*             <span class="navbar-toggler-icon"></span> *@
            @*         </button> *@
            @*         <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between"> *@
            @*             <ul class="navbar-nav flex-grow-1"> *@
            @*                 <li class="nav-item"> *@
            @*                     <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a> *@
            @*                 </li> *@
            @*                 <li class="nav-item"> *@
            @*                     <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a> *@
            @*                 </li> *@
            @*             </ul> *@
            @*         </div> *@
            @*     </div> *@
            @* </nav> *@
       
        <div class="container-fluid p-0" style="min-width:1000px">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    
    @await Component.InvokeAsync("Footer")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/plugins/toastr/toastr.min.js" asp-append-version="true"></script>
     
    <script>
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };
    </script>

    <script>
         
        $('#btnHeaderUser').on('click', function () {
            $('#LogInModalParent')
                .css('display', 'flex')   // 🔥 force flex
                .hide()
                .fadeIn(200);

                $("#LogInEmail").focus();

        });

        $('#btnCloseLogIn').on('click', function () {
            $('#LogInModalParent').fadeOut(200);
        });

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
